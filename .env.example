AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# S3 bucket name where product images + videos will be stored
BUG_IMAGES_BUCKET=YOUR_BUCKET_NAME

# Optional: control object ACL. Leave unset if your bucket blocks ACLs.
# S3_OBJECT_ACL=public-read

# Existing app envs (examples)
SESSION_SECRET=change-me
BASE_URL=http://localhost:3000

# SMTP mail (Gmail) - for email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_username@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="GiftHouse <your_gmail_username@gmail.com>"

# Used to build verification links in emails
APP_URL=https://your-domain.com

