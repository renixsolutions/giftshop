<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Curated By Aissh | Premium Gifts, Hampers & Gift Boxes Online in India' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Discover luxury curated gift boxes and personalized hampers at Curated By Aissh. Perfect for birthdays, anniversaries, corporate events, and weddings. Handcrafted with love and delivered across India.' %>">
  <meta name="keywords" content="curatedbyaissh, curated by aissh, gift shop online india, curated gift boxes india, luxury hampers, personalized gifts, corporate gifting, birthday hampers, wedding gifts india, customized gift sets, unique gift boxes, premium gift packaging, curated luxury gifts">
  <meta name="robots" content="index, follow">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://curatedbyaissh.com/">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Curated By Aissh | Premium Gifts & Hampers' %>">
  <meta property="og:description" content="Premium curated gift boxes and bespoke hampers, crafted with love and delivered across India. Making every occasion unforgettable.">
  <meta property="og:image" content="https://curatedbyaissh.com/images/logofooter.png">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://curatedbyaissh.com/">
  <meta property="twitter:title" content="Curated By Aissh | Premium Gifts & Hampers">
  <meta property="twitter:description" content="Discover luxury curated gift boxes and personalized hampers. Delivered across India.">
  <meta property="twitter:image" content="https://curatedbyaissh.com/images/logofooter.png">
  <% if (typeof csrfToken !== 'undefined') { %>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <% } %>
  <link rel="stylesheet" href="/css/gift-house.css">
  <link rel="icon" type="image/png" href="/images/ganeshji.png">
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>

<!-- Toast container for flash messages -->
<div class="toast-container" id="toastContainer" style="position:fixed;bottom:90px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>
<script>
function showToast(message, type, duration) {
  type = type || 'info'; duration = duration || 5000;
  var c = document.getElementById('toastContainer');
  if (!c) return;
  var t = document.createElement('div');
  t.style.cssText = 'background:#fff;border-radius:12px;padding:14px 18px;box-shadow:0 8px 24px rgba(0,0,0,.15);border-left:4px solid #C4622D;max-width:320px;';
  if (type === 'success') t.style.borderLeftColor = '#2E7D4F';
  if (type === 'error') t.style.borderLeftColor = '#c53030';
  t.textContent = message;
  c.appendChild(t);
  if (duration > 0) setTimeout(function(){ if (t.parentNode) t.parentNode.removeChild(t); }, duration);
}
<% if (typeof flash !== 'undefined' && flash && flash.message) { %>
document.addEventListener('DOMContentLoaded', function(){ showToast('<%= (flash.message || "").replace(/'/g, "\\'") %>', '<%= flash.type || "info" %>'); });
<% } %>
</script>

<!-- Auth modals (Sign in / Sign up separately) -->
<div id="authModalOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.50);backdrop-filter:blur(4px);z-index:980;"></div>

<!-- Sign in modal -->
<div id="authLoginModal" style="display:none;position:fixed;inset:0;z-index:985;align-items:center;justify-content:center;padding:16px;">
  <div style="background:#fff;border-radius:22px;max-width:440px;width:100%;box-shadow:0 22px 60px rgba(0,0,0,.30);overflow:hidden;border:1px solid rgba(0,0,0,.04);">
    <div style="padding:18px 22px;border-bottom:1px solid #f1e7dd;display:flex;justify-content:space-between;align-items:center;">
      <div style="display:flex;flex-direction:column;gap:2px;">
        <div style="font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#c37a45;">Welcome</div>
        <div style="font-family:'Playfair Display',serif;font-weight:700;font-size:20px;color:var(--ink);">Sign in to GiftHouse</div>
      </div>
      <button type="button" id="authLoginModalClose" aria-label="Close" style="border:none;background:rgba(15,12,10,0.04);width:30px;height:30px;border-radius:999px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;color:#3b2a20;">×</button>
    </div>
    <div style="padding:18px 22px 20px;max-height:70vh;overflow:auto;">
      <form id="authLoginForm" action="/auth/login" method="POST">
        <%- include('../partials/csrf-token') %>
        <input type="hidden" name="redirectTo" class="js-auth-redirect">
        <div style="margin-bottom:14px;font-size:13px;color:var(--muted);">Sign in to manage your orders, save addresses and track your hampers.</div>

        <div style="margin-bottom:12px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Email</label>
          <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
        </div>

        <div style="margin-bottom:16px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Password</label>
          <input type="password" name="password" required minlength="6" autocomplete="current-password" placeholder="Enter your password" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
          <div style="margin-top:6px;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--muted);">
            <span>Minimum 6 characters</span>
            <a href="/forgot-password" style="color:var(--ink);text-decoration:none;font-weight:500;">Forgot?</a>
          </div>
        </div>

        <button type="submit" style="width:100%;padding:11px 0;border:none;border-radius:999px;background:var(--ink);color:#fff;font-weight:600;font-size:14px;cursor:pointer;box-shadow:0 10px 26px rgba(0,0,0,.18);">Login</button>

        <!-- Extra Create Account button (requested) -->
        <div style="margin-top:10px;">
          <button
            type="button"
            style="width:100%;padding:10px 0;border:1px solid rgba(0,0,0,.08);border-radius:999px;background:#fff;color:var(--ink);font-weight:600;font-size:14px;cursor:pointer;box-shadow:none;"
            onclick="window.__giftAuthOpen && window.__giftAuthOpen('register')"
          >Create Account</button>
        </div>

        <div style="margin-top:10px;font-size:11px;color:var(--muted);text-align:center;">
          New to GiftHouse?
          <button type="button" style="border:none;background:none;color:var(--ink);font-weight:600;cursor:pointer;padding:0 2px;" onclick="window.__giftAuthOpen && window.__giftAuthOpen('register')">Create an account</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Sign up modal -->
<div id="authRegisterModal" style="display:none;position:fixed;inset:0;z-index:985;align-items:center;justify-content:center;padding:16px;">
  <div style="background:#fff;border-radius:22px;max-width:440px;width:100%;box-shadow:0 22px 60px rgba(0,0,0,.30);overflow:hidden;border:1px solid rgba(0,0,0,.04);">
    <div style="padding:18px 22px;border-bottom:1px solid #f1e7dd;display:flex;justify-content:space-between;align-items:center;">
      <div style="display:flex;flex-direction:column;gap:2px;">
        <div style="font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#c37a45;">Welcome</div>
        <div style="font-family:'Playfair Display',serif;font-weight:700;font-size:20px;color:var(--ink);">Create your GiftHouse account</div>
      </div>
      <button type="button" id="authRegisterModalClose" aria-label="Close" style="border:none;background:rgba(15,12,10,0.04);width:30px;height:30px;border-radius:999px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;color:#3b2a20;">×</button>
    </div>
    <div style="padding:18px 22px 20px;max-height:70vh;overflow:auto;">
      <form id="authRegisterForm" action="/auth/register" method="POST">
        <%- include('../partials/csrf-token') %>
        <input type="hidden" name="redirectTo" class="js-auth-redirect">
        <div style="margin-bottom:14px;font-size:13px;color:var(--muted);">Create your account to save favourites, remember details and checkout faster.</div>

        <div style="margin-bottom:10px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Full Name</label>
          <input type="text" name="name" required autocomplete="name" placeholder="Your full name" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
        </div>

        <div style="margin-bottom:10px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Email</label>
          <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
        </div>

        <div style="margin-bottom:10px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Phone (10‑digit)</label>
          <input type="tel" name="phone" pattern="[0-9]{10}" maxlength="10" autocomplete="tel" placeholder="9876543210" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
        </div>

        <div style="margin-bottom:10px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Password</label>
          <input type="password" name="password" required minlength="6" autocomplete="new-password" placeholder="Create a strong password" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
          <div style="margin-top:6px;font-size:11px;color:var(--muted);">At least 6 characters. Use a mix of letters and numbers.</div>
        </div>

        <div style="margin-bottom:10px;">
          <label style="font-size:13px;font-weight:500;color:var(--ink2);">Confirm Password</label>
          <input type="password" name="confirmPassword" required minlength="6" autocomplete="new-password" placeholder="Re-enter your password" style="width:100%;padding:9px 11px;border-radius:11px;border:1px solid var(--border2);font-size:13px;outline:none;">
        </div>

        <button type="submit" style="width:100%;padding:11px 0;border:none;border-radius:999px;background:var(--ink);color:#fff;font-weight:600;font-size:14px;cursor:pointer;box-shadow:0 10px 26px rgba(0,0,0,.18);">Create account</button>

        <div style="margin-top:10px;font-size:11px;color:var(--muted);text-align:center;">
          Already have an account?
          <button type="button" style="border:none;background:none;color:var(--ink);font-weight:600;cursor:pointer;padding:0 2px;" onclick="window.__giftAuthOpen && window.__giftAuthOpen('login')">Log in</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function(){
    var overlay = document.getElementById('authModalOverlay');
    var modalLogin = document.getElementById('authLoginModal');
    var modalRegister = document.getElementById('authRegisterModal');
    var btnCloseLogin = document.getElementById('authLoginModalClose');
    var btnCloseRegister = document.getElementById('authRegisterModalClose');
    function openModal(mode){
      if(!overlay) return;
      overlay.style.display = 'block';
      if(modalLogin) modalLogin.style.display = mode === 'login' ? 'flex' : 'none';
      if(modalRegister) modalRegister.style.display = mode === 'register' ? 'flex' : 'none';
      
      // Dynamic redirect: capture current page context
      var currentPath = window.location.pathname + window.location.search;
      document.querySelectorAll('.js-auth-redirect').forEach(function(input) {
        input.value = currentPath;
      });

      document.body.style.overflow = 'hidden';
    }
    function closeModal(){
      if(!overlay) return;
      overlay.style.display = 'none';
      if(modalLogin) modalLogin.style.display = 'none';
      if(modalRegister) modalRegister.style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('click', function(e){
      var t = e.target;
      if(t && t.classList && t.classList.contains('nav-cta') && t.textContent.trim().toLowerCase() === 'sign in'){
        e.preventDefault();
        openModal('login');
      }
    });
    if(btnCloseLogin) btnCloseLogin.addEventListener('click', closeModal);
    if(btnCloseRegister) btnCloseRegister.addEventListener('click', closeModal);
    if(overlay) overlay.addEventListener('click', closeModal);
    // Close on Esc
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape'){ closeModal(); }
    });
    // Burger toggle
    var burger = document.getElementById('navBurger');
    var nav = document.querySelector('.nav');
    if(burger && nav){
      burger.addEventListener('click', function(){
        nav.classList.toggle('nav-open');
      });
    }
    // Expose auth state for other scripts (if needed)
    window.GIFT_USER_LOGGED_IN = <%= typeof userId !== 'undefined' && userId ? 'true' : 'false' %>;
    // Intercept auth-required actions (only on catalog/collections pages)
    document.addEventListener('click', function(e){
      if(window.GIFT_USER_LOGGED_IN === true || window.GIFT_USER_LOGGED_IN === 'true') return;
      if(!(window.location.pathname.startsWith('/catalog') || window.location.pathname.startsWith('/collections'))) return;
      var target = e.target.closest('[data-requires-auth=\"true\"]');
      if(target){
        e.preventDefault();
        openModal('login');
      }
    });
    // Explicit login/register triggers from links/buttons
    document.addEventListener('click', function(e){
      var t = e.target.closest('.js-open-auth-login');
      if(t){
        e.preventDefault();
        openModal('login');
        return;
      }
      var r = e.target.closest('.js-open-auth-register');
      if(r){
        e.preventDefault();
        openModal('register');
      }
    });
    // Expose for other links
    window.__giftAuthOpen = openModal;
  })();
</script>

<!-- Global Brand Loader (Bottom Floating) -->
<div id="globalLoader" style="position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(40px);background:var(--ink);color:#fff;padding:14px 28px;border-radius:999px;box-shadow:0 12px 40px rgba(0,0,0,0.3);z-index:99999;display:flex;align-items:center;gap:14px;opacity:0;pointer-events:none;transition:all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(8px);">
  <div style="width:22px;height:22px;display:flex;align-items:center;justify-content:center;background:var(--accent);border-radius:50%;animation:loader-bounce 1s infinite alternate;">
    <i class="bi bi-heart-fill" style="font-size:10px;color:#fff;"></i>
  </div>
  <div style="display:flex;flex-direction:column;gap:1px;">
    <span style="font-family:'Playfair Display',serif;font-size:15px;font-weight:700;letter-spacing:0.5px;line-height:1;">Curating Gifts...</span>
    <span style="font-size:10px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:1px;font-weight:600;">Curated By Aissh</span>
  </div>
</div>

<style>
@keyframes loader-bounce {
  from { transform: translateY(0); }
  to { transform: translateY(-4px); }
}
.loader-active {
  opacity: 1 !important;
  transform: translateX(-50%) translateY(0) !important;
  pointer-events: auto !important;
}
</style>

<script>
(function() {
  var globalLoader = document.getElementById('globalLoader');
  
  window.showLoader = function() {
    if(globalLoader) globalLoader.classList.add('loader-active');
  };
  
  window.hideLoader = function() {
    if(globalLoader) globalLoader.classList.remove('loader-active');
  };

  // Show loader on page transitions for a premium feel
  window.addEventListener('beforeunload', function() {
    window.showLoader();
  });

  // Small delay to ensure any existing loader is cleared on fresh load
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(window.hideLoader, 400);
  });
  
  // Also hook into AJAX if needed (for more complex apps)
  // For now, let's keep it simple as per user request
})();
</script>

<% if (typeof flash !== 'undefined' && flash && flash.message && flash.message.includes('login')) { %>
<script>
  document.addEventListener('DOMContentLoaded', function(){
    if(window.__giftAuthOpen){ window.__giftAuthOpen('login'); }
  });
</script>
<% } %>
