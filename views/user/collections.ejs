<%- include('../partials/header-gift') %>
<%- include('../partials/navbar-gift', { 
  currentPage: 'catalog',
  cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
  userId: typeof userId !== 'undefined' ? userId : null 
}) %>

<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="container mt-3">
    <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
      <%= flash.message %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  </div>
<% } %>

<!-- GiftHouse-style hero -->
<div class="page-hero">
  <div class="breadcrumb">
    <a href="/">Home</a>
    <span>›</span>
    <span style="color:var(--ink2);">All Collections</span>
  </div>
  <div class="page-hero-inner">
    <div>
      <div class="page-hero-title">All Gift Collections</div>
      <div class="page-hero-sub">
        Handpicked hampers and gift boxes for every heart and occasion.
      </div>
    </div>
    <div style="font-size:13px;color:var(--muted);">
      Showing
      <strong style="color:var(--ink);">
        <%= products && products.length ? products.length : 0 %>
      </strong>
      products
    </div>
  </div>
</div>

<!-- Two-column shop layout -->
<div class="shop-layout">
  <aside class="sidebar">
    <%- include('../partials/filters-panel') %>
  </aside>

  <div class="main-content">
    <div class="toolbar">
      <div class="result-meta">
        Beautifully curated gifts, ready to ship.
      </div>
    </div>

    <div class="product-grid" id="productsGrid">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <div class="pcard">
            <div class="pcard-img" style="background:#FBF0E8;">
              <a href="/products/<%= product.id %>" style="display:block;width:100%;height:100%;">
                <img
                  src="<%= product.image || '' %>"
                  alt="<%= product.title %>"
                  style="width:100%;height:100%;object-fit:cover;border-radius:18px 18px 0 0;"
                  onerror="this.onerror=null; this.src='data:image/svg+xml;base64,';"
                >
              </a>
            </div>
            <div class="pcard-body">
              <div class="pcard-meta">
                <span class="pcard-cat"><%= product.category || 'Gift Box' %></span>
              </div>

              <div class="pcard-name"><%= product.title %></div>

              <div class="pcard-rating">
                <% if (product.avgRating && product.avgRating > 0) { %>
                  <div class="stars">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <span class="star <%= i > Math.round(product.avgRating) ? 'empty' : '' %>"></span>
                    <% } %>
                  </div>
                  <span><%= product.avgRating %> (<%= product.totalRatings || 0 %>)</span>
                <% } else { %>
                  <span style="font-size:12px;color:var(--muted);">No ratings yet</span>
                <% } %>
              </div>

                <div class="pcard-foot">
                <div class="pcard-prices">
                  <span class="pcard-price">
                    ₹<%= product.price.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                  </span>
                  <% if (product.original_price && product.original_price > product.price) { %>
                    <span class="pcard-old">
                      ₹<%= product.original_price.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                    </span>
                  <% } %>
                </div>

                <% if (product.stock > 0) { %>
                  <% if (typeof userId !== 'undefined' && userId) { %>
                    <form action="/cart/add" method="POST" id="addToCartForm<%= product.id %>">
                      <%- include('../partials/csrf-token') %>
                      <input type="hidden" name="productId" value="<%= product.id %>">
                      <input type="hidden" name="quantity" value="1">
                      <button
                        type="submit"
                        class="pcard-add"
                        onclick="event.stopPropagation()"
                        aria-label="Add to cart"
                      >
                        +
                      </button>
                    </form>
                  <% } else { %>
                    <button
                      type="button"
                      class="pcard-add js-open-auth-login"
                      onclick="event.stopPropagation(); if (window.__giftAuthOpen) window.__giftAuthOpen('login');"
                      aria-label="Login to order"
                    >
                      +
                    </button>
                  <% } %>
                <% } else { %>
                  <span style="font-size:12px;color:var(--muted);">Out of stock</span>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="no-products">
          <i class="bi bi-inbox" style="font-size: 3rem; color: #ddd;"></i>
          <p>No products found for these filters.</p>
        </div>
      <% } %>
    </div>

    <div id="loadingIndicator" class="catalog-loading" style="display:none;">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
      <p class="mt-3 text-muted">Loading more products...</p>
    </div>

    <div id="endOfProducts" class="catalog-end" style="display:none;">
      <p class="text-muted">You've reached the end of the collection.</p>
    </div>
  </div>
</div>

<style>
  .page-hero {
    background: var(--warm);
    border-bottom: 1px solid var(--border);
    padding: 36px 48px 20px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    color: var(--faint);
    margin-bottom: 12px;
  }
  .breadcrumb a {
    color: var(--muted);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--accent);
  }
  .page-hero-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
  }
  .page-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 38px;
    font-weight: 900;
    color: var(--ink);
    line-height: 1.05;
    margin-bottom: 6px;
  }
  .page-hero-sub {
    font-size: 14px;
    color: var(--muted);
  }

  .shop-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100vh - 72px);
  }
  .sidebar {
    border-right: 1px solid var(--border);
    background: #fff;
    padding: 24px 20px;
    position: sticky;
    top: 72px;
    height: calc(100vh - 72px);
    overflow-y: auto;
  }
  .main-content {
    padding: 24px 32px 40px;
  }
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    flex-wrap: wrap;
    gap: 10px;
  }
  .result-meta {
    font-size: 13px;
    color: var(--muted);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .pcard {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    cursor: pointer;
    transition: transform .25s, box-shadow .25s, border-color .25s;
    display: flex;
    flex-direction: column;
  }
  .pcard:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(28,16,8,.12);
    border-color: var(--border2);
  }
  .pcard-img {
    height: 210px;
  }
  .pcard-body {
    padding: 16px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pcard-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: var(--faint);
  }
  .pcard-name {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }
  .pcard-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--muted);
  }
  .pcard-rating .stars {
    display: flex;
    gap: 2px;
  }
  .pcard-rating .star {
    width: 11px;
    height: 11px;
    background: var(--gold);
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
  }
  .pcard-rating .star.empty {
    background: var(--border2);
  }
  .pcard-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
  }
  .pcard-prices {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .pcard-price {
    font-size: 19px;
    font-weight: 700;
    color: var(--accent);
    font-family: 'Playfair Display', serif;
  }
  .pcard-old {
    font-size: 13px;
    color: var(--faint);
    text-decoration: line-through;
  }
  .pcard-add {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--ink);
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    cursor: pointer;
    transition: background .2s, transform .2s;
    text-decoration: none;
  }
  .pcard-add:hover {
    background: var(--accent);
    transform: scale(1.05);
    color: #fff;
  }

  .no-products,
  .catalog-loading,
  .catalog-end {
    text-align: center;
    padding: 40px 0;
  }

  @media (max-width: 1100px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 860px) {
    .shop-layout {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      height: 0;
      padding: 0;
      margin: 0;
      border: none;
      overflow: visible;
    }
    .page-hero {
      padding: 24px 16px 16px;
    }
    .main-content {
      padding: 20px 16px 32px;
    }
  }
  @media (max-width: 640px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
    .page-hero-title {
      font-size: 28px;
    }
  }
</style>

<script>
    // Infinite Scroll for Collections
    (function() {
        let isLoading = false;
        let hasMore = <%= typeof hasMore !== 'undefined' ? hasMore : false %>;
        let currentOffset = <%= typeof products !== 'undefined' ? products.length : 0 %>;
        const limit = 20;
        const category = '<%= typeof selectedCategory !== 'undefined' ? selectedCategory : 'all' %>';
        const search = '<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>';
        const userId = '<%= typeof userId !== 'undefined' ? userId : '' %>';
        const csrfToken = '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>';
        
        function renderProductCard(product) {
            const qrCodeHtml = product.qr_code ? `
                <div class="product-qr-code-icon" style="position: absolute; top: 10px; right: 10px; z-index: 10; cursor: pointer; background: rgba(255, 255, 255, 0.9); padding: 8px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);" onclick="openQRCodeModal(${JSON.stringify(product).replace(/"/g, '&quot;')})">
                    ${product.qr_code_image ? 
                        `<img src="${product.qr_code_image}" alt="QR Code" style="width: 50px; height: 50px; display: block;">` : 
                        `<i class="bi bi-qr-code-scan" style="font-size: 2rem; color: var(--veera-accent-dark);"></i>`
                    }
                </div>
            ` : '';
            
            const saleBadge = product.discount_percentage && product.discount_percentage > 0 ? 
                '<span class="sale-badge">Sale</span>' : '';
            
            const ratingHtml = product.avgRating && product.avgRating > 0 ? `
                <div class="product-rating mb-2">
                    <div class="d-flex align-items-center">
                        <div class="star-rating me-2">
                            ${Array.from({length: 5}, (_, i) => 
                                `<i class="bi bi-star${i < Math.round(product.avgRating) ? '-fill' : ''} text-warning" style="font-size: 0.9rem;"></i>`
                            ).join('')}
                        </div>
                        <span class="rating-text" style="font-size: 0.85rem; color: #666;">
                            <strong>${product.avgRating}</strong> (${product.totalRatings || 0})
                        </span>
                    </div>
                </div>
            ` : '<div class="product-rating mb-2"><span class="text-muted" style="font-size: 0.85rem;">No ratings yet</span></div>';
            
            const originalPriceHtml = product.original_price && product.original_price > product.price ? 
                `<span class="original-price">Rs. ${parseFloat(product.original_price).toLocaleString('en-IN', {minimumFractionDigits: 2})}</span>` : '';
            
            const discountBadge = product.discount_percentage && product.discount_percentage > 0 ? 
                `<span class="discount-badge">${product.discount_percentage}% OFF</span>` : '';
            
            const addToCartHtml = product.stock > 0 && userId ? `
                <form action="/cart/add" method="POST" class="d-inline w-100" id="addToCartForm${product.id}">
                    <input type="hidden" name="_csrf" value="${csrfToken}">
                    <input type="hidden" name="productId" value="${product.id}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="btn btn-gradient-modern w-100">
                        <i class="bi bi-cart-plus"></i> ADD TO CART
                    </button>
                </form>
            ` : product.stock > 0 ? `
                <button type="button" class="btn btn-gradient-modern w-100 js-open-auth-login"
                        onclick="if (window.__giftAuthOpen) window.__giftAuthOpen('login');">
                    <i class="bi bi-box-arrow-in-right"></i> Login to Order
                </button>
            ` : '<button class="btn btn-secondary w-100" disabled style="padding: 12px; border-radius: 8px;">Out of Stock</button>';
            
            return `
                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
                    <div class="card product-card h-100 shadow-sm">
                        <div class="product-image-wrapper" style="position: relative;">
                            ${saleBadge}
                            ${qrCodeHtml}
                            <a href="/products/${product.id}">
                                <img src="${product.image || ''}" class="card-img-top" alt="${product.title}" style="height: 280px; object-fit: cover; width: 100%;" onerror="this.onerror=null; this.src='data:image/svg+xml;base64,';"
                            </a>
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <h6 class="card-title mb-2" style="min-height: 45px; font-weight: 600;">${product.title}</h6>
                            ${ratingHtml}
                            <div class="price-section mb-3">
                                ${originalPriceHtml}
                                <div class="mt-1">
                                    <span class="current-price">Rs. ${parseFloat(product.price).toLocaleString('en-IN', {minimumFractionDigits: 2})}</span>
                                    ${discountBadge}
                                </div>
                            </div>
                            <div class="mt-auto">
                                ${product.stock > 0 ? `<a href="/products/${product.id}" class="btn btn-light-modern w-100 mb-2">VIEW DETAILS</a>` : ''}
                                ${addToCartHtml}
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }
        
        async function loadMoreProducts() {
            if (isLoading || !hasMore) return;
            
            isLoading = true;
            document.getElementById('loadingIndicator').style.display = 'block';
            
            try {
                const params = new URLSearchParams({
                    limit: limit,
                    offset: currentOffset,
                    search: search
                });
                // Get categories from URL (can be multiple)
                const urlParams = new URLSearchParams(window.location.search);
                const urlCategories = urlParams.getAll('categories');
                if (urlCategories.length > 0) {
                    urlCategories.forEach(cat => params.append('categories', cat));
                } else if (category && category !== 'all') {
                    // Backward compatibility: single category
                    params.append('category', category);
                }
                if (minPrice) params.append('minPrice', minPrice);
                if (maxPrice) params.append('maxPrice', maxPrice);
                if (sortBy) params.append('sortBy', sortBy);
                if (sortOrder) params.append('sortOrder', sortOrder);
                
                const response = await fetch(`/api/collections?${params}`);
                const data = await response.json();
                
                if (data.success && data.products.length > 0) {
                    const grid = document.getElementById('productsGrid');
                    data.products.forEach(product => {
                        grid.insertAdjacentHTML('beforeend', renderProductCard(product));
                    });
                    
                    currentOffset = data.offset;
                    hasMore = data.hasMore;
                    
                    if (!hasMore) {
                        document.getElementById('endOfProducts').style.display = 'block';
                    }
                } else {
                    hasMore = false;
                    document.getElementById('endOfProducts').style.display = 'block';
                }
            } catch (error) {
                console.error('Error loading more products:', error);
            } finally {
                isLoading = false;
                document.getElementById('loadingIndicator').style.display = 'none';
            }
        }
        
        // Scroll event listener
        window.addEventListener('scroll', () => {
            if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 1000) {
                loadMoreProducts();
            }
        });
    })();
    
    // Quantity control functions
</script>

<%- include('../partials/footer-gift') %>

