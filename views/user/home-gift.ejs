<script>
  let currentAdSlide = 0;
  const adTrack = document.getElementById('adSliderTrack');
  const adDots = document.querySelectorAll('.ad-dot');
  const totalSlides = 3;
  let slideInterval;

  function updateSlider() {
    if(!adTrack) return;
    adTrack.style.transform = `translateX(-${currentAdSlide * 100}%)`;
    adDots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentAdSlide);
    });
  }

  function nextSlide() {
    currentAdSlide = (currentAdSlide + 1) % totalSlides;
    updateSlider();
  }

  function goToSlide(index) {
    currentAdSlide = index;
    updateSlider();
    resetInterval();
  }

  function resetInterval() {
    clearInterval(slideInterval);
    slideInterval = setInterval(nextSlide, 5000);
  }

  if(adTrack) {
    slideInterval = setInterval(nextSlide, 5000);
  }
</script>
