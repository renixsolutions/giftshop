<%- include('../partials/header-gift') %>
<%- include('../partials/navbar-gift', { 
  currentPage: 'cart',
  cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
  userId: typeof userId !== 'undefined' ? userId : null 
}) %>

<div class="cart-wrap">
  <div class="cart-main">
    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (cartItems && cartItems.length > 0) { %>
      <div class="cart-title">
        Your Cart
        <span style="font-size:14px;color:var(--muted);font-family:'Outfit',sans-serif;font-weight:400;">
          (<%= cartItems.length %> item<%= cartItems.length > 1 ? 's' : '' %>)
        </span>
      </div>

      <% cartItems.forEach(item => { %>
        <div class="ci">
          <div class="ci-img">
            <% if (item.item_type === 'hamper') { %>
              🎁
            <% } else { 
                 let imgSrc = '';
                 if (item.image) {
                   const raw = String(item.image).trim();
                   if (raw.startsWith('http://') || raw.startsWith('https://')) {
                     imgSrc = raw;
                   } else if (raw.startsWith('/')) {
                     imgSrc = raw;
                   } else {
                     imgSrc = '/uploads/' + raw;
                   }
                 }
            %>
              <img src="<%= imgSrc %>"
                   alt="<%= item.title %>"
                   style="width:100%;height:100%;object-fit:cover;border-radius:inherit;"
                   onerror="this.onerror=null;this.style.display='none';">
            <% } %>
          </div>
          <div class="ci-body">
            <div class="ci-cat">
              <%= item.item_type === 'hamper' ? 'Custom Hamper' : (item.category || 'Gift') %>
            </div>
            <div class="ci-name"><%= item.title %></div>
            <div class="ci-meta">
              <% if (item.item_type === 'hamper' && item.hamper_data) { %>
                <%= item.hamper_data.boxName %> · <%= (item.hamper_data.items || []).map(i => i.name).join(' · ') %>
              <% } else { %>
                ₹<%= Number(item.price).toLocaleString('en-IN', {minimumFractionDigits: 2}) %> per unit
              <% } %>
            </div>
            <div class="qty-row">
              <% if (item.item_type === 'hamper') { %>
                <span class="qn">1</span>
              <% } else { %>
                <form action="/cart/<%= item.id %>/update" method="POST" id="updateCartForm<%= item.id %>">
                  <%- include('../partials/csrf-token') %>
                  <input type="hidden" name="quantity" value="<%= item.quantity %>" id="cartQuantityInput<%= item.id %>">
                  <button
                    type="button"
                    class="qb"
                    onclick="decreaseCartQuantityFromBtn(this)"
                    data-item-id="<%= item.id %>"
                    data-max-stock="<%= item.stock %>"
                  >-</button>
                  <span class="qn" id="cartQuantityDisplay<%= item.id %>"><%= item.quantity %></span>
                  <button
                    type="button"
                    class="qb"
                    onclick="increaseCartQuantityFromBtn(this)"
                    data-item-id="<%= item.id %>"
                    data-max-stock="<%= item.stock %>"
                  >+</button>
                </form>
              <% } %>
              <form action="/cart/<%= item.id %>/remove" method="POST" style="display:inline;">
                <%- include('../partials/csrf-token') %>
                <button type="submit" class="ci-rm">Remove</button>
              </form>
            </div>
          </div>
          <div class="ci-price">
            ₹<%= (Number(item.price) * (item.quantity || 1)).toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
          </div>
        </div>
      <% }); %>

      <!-- Fixed delivery charges apply at checkout -->

    <% } else { %>
      <div class="cart-empty-shell">
        <div class="cart-empty-card">
          <div class="cart-empty-icon">🛒</div>
          <h2 class="cart-empty-title">Your cart is empty</h2>
          <p class="cart-empty-sub">Start shopping to add items to your cart. Your saved hampers and gift boxes will appear here.</p>
          <div class="cart-empty-actions">
            <a href="/collections" class="cart-empty-btn">
              Browse Collections
            </a>
            <a href="/build-hamper" class="cart-empty-btn cart-empty-btn--ghost">
              Build a Hamper
            </a>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <% if (cartItems && cartItems.length > 0) { %>
  <div class="cart-sidebar">
    <div class="cs-title">Order Summary</div>
    <% const deliveryFee = 150; %>
    <div class="cs-row"><span>Subtotal</span><span>₹<%= total.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span></div>
    <div class="cs-row"><span>Delivery</span><span>₹<%= deliveryFee.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span></div>
    <div class="cs-total"><span class="cs-total-l">Total</span><span class="cs-total-r">₹<%= (total + deliveryFee).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span></div>
    <button class="btn-block" style="margin-top:18px;" onclick="window.location.href='/orders/checkout'">
      Proceed to Checkout →
    </button>
    <button class="btn-block btn-block-ghost" style="margin-top:8px;" onclick="window.location.href='/collections'">
      Continue Shopping
    </button>
    <div class="secure-note">🔒 <span>Secure checkout · SSL encrypted</span></div>
  </div>
  <% } %>
</div>

<script>
    // Cart quantity control functions
    function increaseCartQuantityFromBtn(btn) {
        if (!btn) return;
        const itemId = btn.dataset.itemId;
        const maxStock = parseInt(btn.dataset.maxStock, 10);
        if (!itemId || isNaN(maxStock)) return;
        increaseCartQuantity(itemId, maxStock);
    }
    
    function decreaseCartQuantityFromBtn(btn) {
        if (!btn) return;
        const itemId = btn.dataset.itemId;
        const maxStock = parseInt(btn.dataset.maxStock, 10);
        if (!itemId || isNaN(maxStock)) return;
        decreaseCartQuantity(itemId, maxStock);
    }
    
    function increaseCartQuantity(itemId, maxStock) {
        const display = document.getElementById('cartQuantityDisplay' + itemId);
        const input = document.getElementById('cartQuantityInput' + itemId);
        const form = document.getElementById('updateCartForm' + itemId);
        if (display && input && form) {
            let currentValue = parseInt(display.textContent) || 1;
            if (currentValue < maxStock) {
                currentValue++;
                display.textContent = currentValue;
                input.value = currentValue;
                form.submit();
            }
        }
    }
    
    function decreaseCartQuantity(itemId, maxStock) {
        const display = document.getElementById('cartQuantityDisplay' + itemId);
        const input = document.getElementById('cartQuantityInput' + itemId);
        const form = document.getElementById('updateCartForm' + itemId);
        if (display && input && form) {
            let currentValue = parseInt(display.textContent) || 1;
            if (currentValue > 1) {
                currentValue--;
                display.textContent = currentValue;
                input.value = currentValue;
                form.submit();
            }
        }
    }
</script>

<%- include('../partials/footer-gift') %>

<style>
  .cart-wrap{
    max-width:1120px;
    margin:24px auto 56px;
    padding:0 24px;
    display:grid;
    grid-template-columns:1fr 360px;
    gap:28px;
  }
  .cart-main{
    padding:32px 0;
  }
  .cart-title{
    font-family:'Playfair Display',serif;
    font-size:26px;
    font-weight:900;
    color:var(--ink);
    margin-bottom:20px;
  }
  .cart-sidebar{
    padding:32px 28px;
    background:var(--warm);
    border-radius:20px;
    border:1px solid var(--border);
  }
  .cs-title{
    font-family:'Playfair Display',serif;
    font-size:20px;
    font-weight:700;
    margin-bottom:18px;
    color:var(--ink);
  }
  .cs-row{
    display:flex;
    justify-content:space-between;
    font-size:13.5px;
    color:var(--muted);
    padding:4px 0;
  }
  .cs-total{
    display:flex;
    justify-content:space-between;
    padding-top:14px;
    border-top:1.5px solid var(--border2);
    margin-top:6px;
  }
  .cs-total-l{
    font-size:15px;
    font-weight:600;
    color:var(--ink);
  }
  .cs-total-r{
    font-family:'Playfair Display',serif;
    font-size:22px;
    font-weight:700;
    color:var(--accent);
  }
  .secure-note{
    display:flex;
    align-items:center;
    gap:8px;
    font-size:12px;
    color:var(--muted);
    margin-top:14px;
  }
  .btn-block{
    display:block;
    width:100%;
    padding:12px 16px;
    background:var(--accent);
    color:#fff;
    border:none;
    border-radius:12px;
    font-family:'Outfit',sans-serif;
    font-size:14px;
    font-weight:600;
    cursor:pointer;
    letter-spacing:.04em;
    transition:background .2s, transform .1s, box-shadow .2s;
    box-shadow:0 6px 18px rgba(0,0,0,.18);
  }
  .btn-block:hover{
    background:var(--ink);
    transform:translateY(-1px);
  }
  .btn-block-ghost{
    background:#fff;
    color:var(--ink);
    border:1.5px solid var(--border2);
    box-shadow:none;
  }
  .btn-block-ghost:hover{
    border-color:var(--ink);
    background:var(--warm);
  }
  .cart-empty-shell{
    display:flex;
    align-items:center;
    justify-content:center;
    min-height:340px;
  }
  .cart-empty-card{
    background:#fff;
    border-radius:24px;
    padding:40px 32px 36px;
    border:1px solid var(--border);
    box-shadow:0 18px 55px rgba(0,0,0,.08);
    text-align:center;
    max-width:420px;
    width:100%;
  }
  .cart-empty-icon{
    font-size:40px;
    margin-bottom:10px;
  }
  .cart-empty-title{
    font-family:'Playfair Display',serif;
    font-size:22px;
    font-weight:800;
    color:var(--ink);
    margin-bottom:6px;
  }
  .cart-empty-sub{
    font-size:13px;
    color:var(--muted);
    margin-bottom:18px;
  }
  .cart-empty-actions{
    display:flex;
    gap:10px;
    justify-content:center;
    flex-wrap:wrap;
    margin-top: 8px;
  }
  .cart-empty-btn{
    display:inline-block;
    padding:11px 22px;
    border-radius:999px;
    background:var(--ink);
    color:#fff;
    font-size:13px;
    font-weight:600;
    text-decoration:none;
    letter-spacing:.06em;
    box-shadow:0 8px 20px rgba(0,0,0,.2);
    transition:background .2s, transform .1s, box-shadow .2s;
  }
  .cart-empty-btn--ghost{
    background:#fff;
    color:var(--ink);
    border:1.5px solid var(--border2);
    box-shadow:none;
  }
  .cart-empty-btn--ghost:hover{
    background:var(--warm);
    border-color:var(--ink);
    color:var(--ink);
    transform:translateY(-1px);
  }
  .cart-empty-btn:hover{
    background:var(--accent);
    box-shadow:0 10px 24px rgba(0,0,0,.25);
    transform:translateY(-1px);
    color:#fff;
  }
  @media (max-width: 900px){
    .cart-wrap{
      grid-template-columns:1fr;
      padding:0 16px 40px;
      margin-top:16px;
    }
    .cart-sidebar{
      order:-1;
    }
    .cart-empty-card{
      padding:34px 22px 28px;
      border-radius:20px;
    }
  }
</style>

