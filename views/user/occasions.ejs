<%- include('../partials/header-gift') %>
<%- include('../partials/navbar-gift', { 
  currentPage: 'occasions',
  cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
  userId: typeof userId !== 'undefined' ? userId : null 
}) %>

<div class="builder-hero">
  <h1>Gifts for Every <i>Occasion</i></h1>
  <p>Browse curated boxes perfect for birthdays, anniversaries, weddings, corporate events and more.</p>
</div>

<div class="section" style="padding-top:32px;">
  <div class="sec-head sec-head-row">
    <div>
      <div class="sec-tag">Occasions</div>
      <div class="sec-title">Shop by Occasion</div>
      <div class="sec-sub">Pick an occasion and discover ready-to-gift boxes or start building your own.</div>
    </div>
  </div>

  <!-- Dynamic occasion tabs -->
  <div class="occ-tabs">
    <a href="/occasions" class="occ-pill <%= !selectedOccasion ? 'occ-pill--primary' : '' %>" style="text-decoration:none;color:inherit;">All</a>
    <% if (occasions && occasions.length) { %>
      <% occasions.forEach(function(occ){ %>
        <a href="/occasions?occ=<%= occ.slug %>" class="occ-pill <%= selectedOccasion && selectedOccasion.slug === occ.slug ? 'occ-pill--primary' : '' %>" style="text-decoration:none;color:inherit;">
          <%= occ.name %>
        </a>
      <% }); %>
    <% } %>
  </div>

  <!-- Products grid -->
  <div class="pgrid">
    <% if (products && products.length) { %>
      <% products.forEach(function(p){ %>
        <a href="/products/<%= p.id %>" class="pcard">
          <div class="pcard-img">
            <% if (p.image) { %>
              <img src="<%= p.image.startsWith('/uploads') ? p.image : '/uploads/' + p.image %>" alt="<%= p.title %>" style="width:100%;height:100%;object-fit:cover;">
            <% } else { %>
              🎁
            <% } %>
          </div>
          <div class="pcard-body">
            <div class="pcard-cat"><%= p.occasion || p.category || 'Gift' %></div>
            <div class="pcard-name"><%= p.title %></div>
            <div class="pcard-desc"><%= (p.description || '').substring(0, 80) %>...</div>
            <div class="pcard-foot">
              <span class="pcard-price">₹<%= Number(p.price).toLocaleString('en-IN') %></span>
              <span class="pcard-add">+</span>
            </div>
          </div>
        </a>
      <% }); %>
    <% } else { %>
      <p>No products found for this occasion yet.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer-gift') %>

