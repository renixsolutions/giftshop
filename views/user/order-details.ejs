<%- include('../partials/header-gift') %>
<%- include('../partials/navbar-gift', { 
  currentPage: 'orders',
  cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
  userId: typeof userId !== 'undefined' ? userId : null 
}) %>

<style>
    .cart-wrap {
        display: grid;
        grid-template-columns: 1fr 380px;
        min-height: 500px;
    }
    .cart-main {
        padding: 40px 48px;
        border-right: 1px solid var(--border);
    }
    .cart-title {
        font-family: 'Playfair Display', serif;
        font-size: 30px;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 28px;
    }
    .ci {
        display: flex;
        gap: 18px;
        padding: 22px 0;
        border-bottom: 1px solid var(--border);
    }
    .ci-img {
        width: 88px;
        height: 88px;
        border-radius: var(--r);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        flex-shrink: 0;
        background: var(--warm);
        overflow: hidden;
    }
    .ci-body, .ci-price {
        flex: 1;
    }
    .ci-name {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--ink);
    }
    .ci-meta {
        font-size: 12.5px;
        color: var(--muted);
    }
    .ci-price {
        font-size: 20px;
        font-weight: 700;
        color: var(--accent);
        text-align: right;
    }
    .cart-sidebar {
        padding: 32px 28px;
        background: var(--warm);
    }
    .cs-title {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 22px;
    }
    .cs-total {
        display: flex;
        justify-content: space-between;
        padding: 16px 0 0;
        border-top: 1.5px solid var(--border2);
    }
    .cs-total-l, .cs-total-r {
        font-size: 15px;
        font-weight: 600;
    }
    .cs-total-r {
        font-size: 22px;
        color: var(--accent);
    }

    .feedback-section .existing-review {
        background: #fff;
        border: 1px solid var(--border2);
        border-radius: var(--r);
    }
    .star-rating {
        font-size: 1.1rem;
    }
    .star-rating-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 5px;
    }
    .star-rating-input input[type="radio"] {
        display: none;
    }
    .star-rating-input .star-label {
        cursor: pointer;
        font-size: 1.8rem;
        color: var(--border2);
        transition: color 0.2s;
    }
    .star-rating-input .star-label:hover,
    .star-rating-input .star-label:hover ~ .star-label {
        color: var(--gold);
    }
    .star-rating-input input[type="radio"]:checked ~ .star-label,
    .star-rating-input input[type="radio"]:checked + .star-label {
        color: var(--gold);
    }
    .review-form {
        background: var(--warm);
        padding: 24px;
        border-radius: var(--r);
        border: 1px solid var(--border2);
    }
    .review-form h6 {
        color: var(--ink);
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 18px;
    }

    /* Order Status Timeline Styles */
    .status-timeline {
        position: relative;
        padding-left: 35px;
    }
    .status-item {
        position: relative;
        padding-bottom: 28px;
        display: flex;
        align-items: flex-start;
    }
    .status-item:last-child {
        padding-bottom: 0;
    }
    .status-item:last-child .status-line {
        display: none;
    }
    .status-dot {
        position: absolute;
        left: -35px;
        top: 2px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background-color: #fff;
        border: 2px solid var(--border2);
        z-index: 2;
        transition: all 0.3s ease;
    }
    .status-item.active .status-dot {
        background-color: var(--ink);
        border-color: var(--ink);
        box-shadow: 0 0 0 3px rgba(28, 16, 8, 0.1);
    }
    .status-item.current .status-dot {
        background-color: var(--green);
        border-color: var(--green);
        box-shadow: 0 0 0 3px rgba(46, 125, 79, 0.2);
        width: 16px;
        height: 16px;
        left: -36px;
        top: 1px;
    }
    .status-item.cancelled .status-dot {
        background-color: #c53030;
        border-color: #c53030;
        box-shadow: 0 0 0 3px rgba(197, 48, 48, 0.2);
    }
    .status-line {
        position: absolute;
        left: -29px;
        top: 16px;
        width: 2px;
        height: calc(100% - 2px);
        background-color: var(--border2);
        z-index: 1;
    }
    .status-item.active .status-line {
        background-color: var(--ink);
    }
    .status-item.current .status-line {
        background-color: var(--green);
    }
    .status-label {
        font-size: 14px;
        color: var(--muted);
        font-weight: 500;
        transition: all 0.3s ease;
        line-height: 1.2;
    }
    .status-item.active .status-label {
        color: var(--ink);
        font-weight: 600;
    }
    .status-item.current .status-label {
        color: var(--green);
        font-weight: 700;
    }
    .status-item.cancelled .status-label {
        color: #c53030;
        font-weight: 700;
    }
    
    @media (max-width: 992px) {
        .cart-wrap {
            grid-template-columns: 1fr;
        }
        .cart-sidebar {
            border-left: none;
            border-top: 1px solid var(--border);
        }
        .cart-main, .cart-sidebar {
            padding: 24px 16px;
        }
    }
</style>

<div style="max-width: 1160px; margin: 40px auto 120px; padding: 0 24px;">
    <% if (typeof flash !== 'undefined' && flash) { %>
        <div style="background: <%= flash.type === 'error' ? '#fff5f5' : '#f0fdf4' %>; border: 1px solid <%= flash.type === 'error' ? '#feb2b2' : '#bbf7d0' %>; color: <%= flash.type === 'error' ? '#c53030' : '#15803d' %>; padding: 14px 18px; border-radius: var(--r); font-size: 14px; font-weight: 500; margin-bottom: 24px;">
            <%= flash.message %>
        </div>
    <% } %>
    
    <div style="margin-bottom: 20px;">
        <a href="/orders" class="btn-ghost" style="display: inline-flex; align-items: center; gap: 8px; font-size: 13.5px; border-radius: var(--r); padding: 10px 18px; text-decoration: none; color: var(--ink); font-weight: 500; border: 1.5px solid var(--border2);">
            <span style="font-size: 16px;">&larr;</span> Back to Orders
        </a>
    </div>

    <div class="cart-wrap" style="background: #fff; border-radius: var(--rxl); border: 1px solid var(--border); overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.03);">
        
        <!-- Order Items Column -->
        <div class="cart-main">
            <div style="padding-bottom: 24px; margin-bottom: 32px; border-bottom: 1.5px solid var(--border);">
                <h1 class="cart-title" style="margin-bottom: 8px;">Order Details</h1>
                <div style="font-size: 14px; font-weight: 500; color: var(--muted);">Order #<%= order.id %> &bull; Placed on <%= new Date(order.created_at).toLocaleDateString() %></div>
            </div>

            <h6 style="font-family:'Playfair Display',serif; font-size: 20px; font-weight: 700; color:var(--ink); margin-bottom: 24px;">Items in your order</h6>
            
            <% if (orderItems && orderItems.length > 0) { %>
                <% orderItems.forEach(item => { %>
                    <div style="padding: 24px 0; border-bottom: 1px solid var(--border);">
                        
                        <!-- Item Header uses pure custom CSS classes -->
                        <div class="ci" style="border-bottom: none; padding: 0; margin-bottom: 24px; gap: 20px;">
                            <div class="ci-img" style="width: 96px; height: 96px; overflow: hidden; border-radius: var(--r);">
                                <img src="<%= item.image || '' %>" alt="<%= item.title %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null; this.src='data:image/svg+xml;base64,';">
                            </div>
                            <div class="ci-body" style="display: flex; flex-direction: column; justify-content: center;">
                                <div class="ci-name" style="margin-bottom: 6px; font-size: 19px;"><%= item.title %></div>
                                <div class="ci-meta" style="font-size: 13.5px;">Quantity: <strong style="color:var(--ink); font-weight: 600;"><%= item.quantity %></strong></div>
                            </div>
                            <div class="ci-price" style="display: flex; align-items: center; justify-content: flex-end; font-size: 19px;">
                                ₹<%= (item.unit_price * item.quantity).toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                            </div>
                        </div>

                        <!-- Feedback Section Full Width -->
                        <div class="feedback-section" style="width: 100%;">
                            <% if (item.hasReview && item.review) { %>
                                <!-- Existing Review Display -->
                                <div class="existing-review" style="padding: 24px;">
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
                                        <div>
                                            <strong style="font-size: 14px; font-weight: 600; color: var(--ink); display: block;">Your Rating</strong>
                                            <div class="star-rating" style="margin-top: 6px;">
                                                <% for (let i = 1; i <= 5; i++) { %>
                                                    <span style="color: <%= i <= item.review.rating ? 'var(--gold)' : 'var(--border2)' %>; font-size: 18px;">★</span>
                                                <% } %>
                                            </div>
                                        </div>
                                        <button class="btn-ghost edit-review-btn" data-item-id="<%= item.product_id %>" style="padding: 8px 14px; font-size: 12.5px;">
                                            Edit Review
                                        </button>
                                    </div>
                                    <% if (item.review.message) { %>
                                        <p style="margin: 16px 0 0; font-size: 14px; color: var(--ink2); line-height: 1.6;"><%= item.review.message %></p>
                                    <% } %>
                                    <div style="font-size: 11.5px; color: var(--muted); margin-top: 14px;">Reviewed on <%= new Date(item.review.created_at).toLocaleDateString() %></div>
                                </div>
                                
                                <!-- Edit Review Form (Hidden) -->
                                <div class="review-form" id="review-form-<%= item.product_id %>" style="display: none; margin-top: 16px;">
                                    <h6 style="margin-bottom: 18px; margin-top: 0;">Edit Your Review</h6>
                                    <form action="/products/<%= item.product_id %>/review" method="POST" class="review-form-inner">
                                        <%- include('../partials/csrf-token') %>
                                        <input type="hidden" name="productId" value="<%= item.product_id %>">
                                        <input type="hidden" name="orderId" value="<%= order.id %>">
                                        
                                        <div style="margin-bottom: 18px;">
                                            <label style="display: block; font-size: 13.5px; font-weight: 600; color: var(--ink2); margin-bottom: 8px;">Rating</label>
                                            <div class="star-rating-input" style="width: max-content; margin: 0;">
                                                <% for (let i = 5; i >= 1; i--) { %>
                                                    <input type="radio" name="rating" id="rating-<%= item.product_id %>-<%= i %>" value="<%= i %>" <%= item.review.rating === i ? 'checked' : '' %> required>
                                                    <label for="rating-<%= item.product_id %>-<%= i %>" class="star-label">★</label>
                                                <% } %>
                                            </div>
                                        </div>
                                        
                                        <div style="margin-bottom: 20px;">
                                            <label for="message-<%= item.product_id %>" style="display: block; font-size: 13.5px; font-weight: 600; color: var(--ink2); margin-bottom: 8px;">Your Feedback</label>
                                            <textarea id="message-<%= item.product_id %>" name="message" rows="3" placeholder="Share your experience..." style="width: 100%; padding: 14px; box-sizing: border-box; border-radius: var(--r); border: 1.5px solid var(--border2); outline: none; font-size: 14px; font-family: inherit; resize: vertical; display: block;"><%= item.review.message || '' %></textarea>
                                        </div>
                                        
                                        <div style="display: flex; gap: 12px;">
                                            <button type="submit" class="btn-solid" style="padding: 12px 24px;">Update Review</button>
                                            <button type="button" class="btn-ghost cancel-edit-btn" data-item-id="<%= item.product_id %>" style="padding: 12px 24px;">Cancel</button>
                                        </div>
                                    </form>
                                </div>
                            <% } else { %>
                                <!-- New Review Form -->
                                <div class="review-form">
                                    <h6 style="margin-bottom: 18px; margin-top: 0;">Rate & Review This Product</h6>
                                    <form action="/products/<%= item.product_id %>/review" method="POST" class="review-form-inner">
                                        <%- include('../partials/csrf-token') %>
                                        <input type="hidden" name="productId" value="<%= item.product_id %>">
                                        <input type="hidden" name="orderId" value="<%= order.id %>">
                                        
                                        <div style="margin-bottom: 18px;">
                                            <label style="display: block; font-size: 13.5px; font-weight: 600; color: var(--ink2); margin-bottom: 6px;">Rating <span style="color: #c53030;">*</span></label>
                                            <div class="star-rating-input" style="width: max-content; margin: 0;">
                                                <% for (let i = 5; i >= 1; i--) { %>
                                                    <input type="radio" name="rating" id="rating-<%= item.product_id %>-<%= i %>" value="<%= i %>" required>
                                                    <label for="rating-<%= item.product_id %>-<%= i %>" class="star-label">★</label>
                                                <% } %>
                                            </div>
                                            <div style="font-size: 11.5px; color: var(--muted); margin-top: 4px;">Click on a star to rate</div>
                                        </div>
                                        
                                        <div style="margin-bottom: 22px;">
                                            <label for="message-<%= item.product_id %>" style="display: block; font-size: 13.5px; font-weight: 600; color: var(--ink2); margin-bottom: 8px;">Review Message</label>
                                            <textarea id="message-<%= item.product_id %>" name="message" rows="3" placeholder="Share your experience (Optional)" style="width: 100%; box-sizing: border-box; padding: 14px; border-radius: var(--r); border: 1.5px solid var(--border2); outline: none; font-size: 14px; font-family: inherit; resize: vertical; display: block;"></textarea>
                                        </div>
                                        
                                        <button type="submit" class="btn-solid" style="padding: 14px 28px;">Submit Review</button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } %>

        </div>
        
        <!-- Summary Column -->
        <div class="cart-sidebar">
            <h5 class="cs-title" style="margin-bottom: 32px;">Order Status</h5>
            
            <div class="order-status-timeline" style="margin-bottom: 32px;">
                <div class="status-timeline">
                    <!-- Pending -->
                    <div class="status-item <%= order.status === 'pending' || order.status === 'processing' || order.status === 'shipped' || order.status === 'delivered' ? 'active' : '' %> <%= order.status === 'pending' ? 'current' : '' %>">
                        <div class="status-dot"></div>
                        <div class="status-line"></div>
                        <div class="status-label">Pending</div>
                    </div>
                    
                    <!-- Placed (Processing) -->
                    <div class="status-item <%= order.status === 'processing' || order.status === 'shipped' || order.status === 'delivered' ? 'active' : '' %> <%= order.status === 'processing' ? 'current' : '' %>">
                        <div class="status-dot"></div>
                        <div class="status-line"></div>
                        <div class="status-label">Placed</div>
                    </div>
                    
                    <!-- Shipped -->
                    <div class="status-item <%= order.status === 'shipped' || order.status === 'delivered' ? 'active' : '' %> <%= order.status === 'shipped' ? 'current' : '' %>">
                        <div class="status-dot"></div>
                        <div class="status-line"></div>
                        <div class="status-label">Shipped</div>
                    </div>
                    
                    <!-- Delivered -->
                    <div class="status-item <%= order.status === 'delivered' ? 'active' : '' %> <%= order.status === 'delivered' ? 'current' : '' %>">
                        <div class="status-dot"></div>
                        <div class="status-label">Delivered</div>
                    </div>
                    
                    <!-- Cancelled -->
                    <% if (order.status === 'cancelled') { %>
                        <div class="status-item cancelled current">
                            <div class="status-dot"></div>
                            <div class="status-label">Cancelled</div>
                        </div>
                    <% } %>
                </div>
            </div>

            <div style="width: 100%; height: 1.5px; background: var(--border2); margin: 32px 0;"></div>

            <% if (order.customer_name || order.shipping_address) { %>
                <div style="margin-bottom: 32px;">
                    <h6 style="font-size: 11.5px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--faint); margin-bottom: 12px; margin-top: 0;">Shipping Address</h6>
                    <div style="font-size: 14px; color: var(--ink2); line-height: 1.6;">
                        <% if (order.customer_name) { %>
                            <strong style="color: var(--ink); font-weight: 600;"><%= order.customer_name %></strong><br>
                        <% } %>
                        <% if (order.customer_phone) { %>
                            <%= order.customer_phone %><br>
                        <% } %>
                        <% if (order.shipping_address) { %>
                            <span style="display: inline-block; margin-top: 6px;"><%= order.shipping_address %></span><br>
                        <% } %>
                        <% if (order.city || order.state || order.pincode) { %>
                            <%= order.city || '' %><%= order.city && order.state ? ', ' : '' %><%= order.state || '' %>
                            <% if (order.pincode) { %>
                                - <%= order.pincode %>
                            <% } %>
                        <% } %>
                    </div>
                </div>
                <div style="width: 100%; height: 1.5px; background: var(--border2); margin: 32px 0;"></div>
            <% } %>

            <div class="cs-total" style="border-top: none; padding-top: 0;">
                <div class="cs-total-l" style="font-size: 16px; color: var(--ink); font-weight: 600;">Total Paid</div>
                <div class="cs-total-r" style="font-size: 24px; font-weight: 700; color: var(--accent);">
                    ₹<%= order.total_amount.toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                </div>
            </div>

            <div style="text-align: center; padding: 14px; margin-top: 16px; background: rgba(46, 125, 79, 0.08); border-radius: var(--r); font-size: 13.5px; font-weight: 600; color: var(--green);">
                Cash on Delivery
            </div>
            
        </div>
    </div>
</div>

<script>
    // Handle edit review button
    document.querySelectorAll('.edit-review-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const itemId = this.getAttribute('data-item-id');
            const reviewForm = document.getElementById('review-form-' + itemId);
            if (reviewForm) {
                reviewForm.style.display = 'block';
                reviewForm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        });
    });
    
    // Handle cancel edit button
    document.querySelectorAll('.cancel-edit-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const itemId = this.getAttribute('data-item-id');
            const reviewForm = document.getElementById('review-form-' + itemId);
            if (reviewForm) {
                reviewForm.style.display = 'none';
            }
        });
    });
    
    // Star rating hover effect
    document.querySelectorAll('.star-rating-input').forEach(container => {
        const labels = container.querySelectorAll('.star-label');
        const inputs = container.querySelectorAll('input[type="radio"]');
        
        labels.forEach((label, index) => {
            label.addEventListener('mouseenter', function() {
                const rating = 5 - index;
                labels.forEach((l, i) => {
                    if (5 - i <= rating) {
                        l.style.color = 'var(--gold)';
                    } else {
                        l.style.color = 'var(--border2)';
                    }
                });
            });
        });
        
        container.addEventListener('mouseleave', function() {
            const checkedInput = container.querySelector('input[type="radio"]:checked');
            labels.forEach((label, index) => {
                if (checkedInput) {
                    const checkedRating = parseInt(checkedInput.value);
                    const labelRating = 5 - index;
                    if (labelRating <= checkedRating) {
                        label.style.color = 'var(--gold)';
                    } else {
                        label.style.color = 'var(--border2)';
                    }
                } else {
                    label.style.color = 'var(--border2)';
                }
            });
        });
        
        inputs.forEach(input => {
            input.addEventListener('change', function() {
                const rating = parseInt(this.value);
                labels.forEach((label, index) => {
                    const labelRating = 5 - index;
                    if (labelRating <= rating) {
                        label.style.color = 'var(--gold)';
                    } else {
                        label.style.color = 'var(--border2)';
                    }
                });
            });
        });
    });
</script>

<%- include('../partials/footer-gift') %>
