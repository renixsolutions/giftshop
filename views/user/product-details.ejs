        color:#e0d2c4;
    }
    .pd-star--on{
        color:#f5b200;
    }
    .pd-hero-rating-val{
        font-weight:600;
        color:var(--ink2);
    }
    .pd-hero-rating-text{
        color:var(--muted);
    }
    .pd-meta-pill {
        padding: 10px 16px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid var(--border);
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1px;
        min-width: 140px;
    }
    .pd-meta-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--faint);
    }
    .pd-meta-value {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--accent);
    }

    .pd-shell {
        max-width: 1120px;
        margin: 24px auto 56px;
        padding: 0 24px;
    }

    .pd-main {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
        gap: 32px;
        align-items: flex-start;
        margin-bottom: 40px;
    }
    .pd-left,
    .pd-right {
        min-width: 0;
    }
    .pd-image-card {
        border-radius: 22px;
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px rgba(28,16,8,.12);
        padding: 12px;
    }
    .pd-image {
        width: 100%;
        height: 440px;
        object-fit: cover;
        border-radius: 18px;
        display: block;
    }
    .pd-thumbs {
        display: flex;
        gap: 8px;
        margin-top: 10px;
        flex-wrap: wrap;
    }
    .pd-thumb {
        width: 70px;
        height: 70px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
        padding: 0;
        background: #fff;
        cursor: pointer;
