    }
    
    /* Review Listing Styles */
    .reviews-section-header {
        margin-bottom: 1.75rem;
    }
    .reviews-title{
        font-family:'Playfair Display',serif;
        font-size:22px;
        font-weight:700;
        color:var(--ink);
        margin:0 0 10px;
    }
    
    .rating-summary-card {
        background: linear-gradient(135deg, rgba(212, 165, 116, 0.1) 0%, rgba(232, 201, 163, 0.1) 100%);
        border: 1px solid rgba(212, 165, 116, 0.2);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
    }
    
    .rating-display {
        display: flex;
