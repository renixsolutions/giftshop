<%- include('../partials/header-gift', { 
    title: product.title + ' | Curated By Aissh',
    metaDescription: (product.description || '').substring(0, 160) + '...'
}) %>
<%- include('../partials/navbar-gift', { 
  currentPage: 'catalog',
  cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
  userId: typeof userId !== 'undefined' ? userId : null 
}) %>

<div class="pd-hero">
    <div class="pd-hero-inner">
        <div>
            <div class="pd-breadcrumb">
                <a href="/">Home</a>
                <span>›</span>
                <a href="/collections">Collections</a>
                <span>›</span>
                <span><%= product.title %></span>
            </div>
            <h1 class="pd-title"><%= product.title %></h1>
            <p class="pd-sub">
                Thoughtfully curated gift, beautifully packed and ready to delight.
            </p>
        </div>
        <% if (avgRating > 0 && totalRatings > 0) { %>
            <div class="pd-hero-rating-right" aria-label="Product rating summary">
                <div class="pd-hero-rating-pill">
                    <div class="pd-hero-rating-left">
                        <span class="pd-hero-rating-val"><%= avgRating %></span><span class="pd-hero-rating-out">/5</span>
                    </div>
                    <div class="pd-hero-rating-stars">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <span class="pd-hero-star <%= i <= Math.round(avgRating) ? 'on' : '' %>">★</span>
                        <% } %>
                    </div>
                    <div class="pd-hero-rating-count">
                        Based on <strong><%= totalRatings || 0 %></strong> <%= totalRatings === 1 ? 'rating' : 'ratings' %>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>

<div class="pd-shell">
    <% if (typeof flash !== 'undefined' && flash && flash.type === 'error') { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= flash.message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="pd-main">
        <div class="pd-left">
            <div class="pd-image-card">
                <img
                    src="<%= product.image || '' %>"
                    alt="<%= product.title %>"
                    class="pd-image"
                    onerror="this.onerror=null; this.src='data:image/svg+xml;base64,';"
                >
                <% if (product.video_url) { %>
                    <video
                        class="pd-video-preview"
                        src="<%= product.video_url %>"
                        controls
                        preload="metadata"
                    ></video>
                <% } %>
            </div>
            
            <%
                const hasVideo = !!(product && product.video_url);
                const hasGalleryThumbs = !!(galleryImages && galleryImages.length > 0);
            %>
            <% if (hasVideo || hasGalleryThumbs) { %>
            <div class="pd-thumbs">
                <% if (hasGalleryThumbs) { %>
                    <% galleryImages.forEach(function(img) { %>
                        <button
                            type="button"
                            class="pd-thumb"
                            onclick="(function(){ var v=document.querySelector('.pd-video-preview'); var imgEl=document.querySelector('.pd-image'); if(v){ v.style.display='none'; } if(imgEl){ imgEl.src='<%= img.image_url %>'; imgEl.style.display='block'; } })()"
                        >
                            <img src="<%= img.image_url %>" alt="" onerror="this.style.display='none'">
                        </button>
                    <% }); %>
                <% } %>

                <% if (hasVideo) { %>
                    <button
                        type="button"
                        class="pd-thumb"
                        onclick="(function(){ var v=document.querySelector('.pd-video-preview'); var img=document.querySelector('.pd-image'); if(v){ v.style.display='block'; try{v.currentTime=0;}catch(e){} } if(img){ img.style.display='none'; } })()"
                        title="Play video"
                    >
                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.04);">
                            <span style="font-size:26px;color:var(--veera-accent-dark);line-height:1;">▶</span>
                        </div>
                    </button>
                <% } %>
            </div>
            <% } %>
        </div>

        <div class="pd-right">
            <div class="pd-summary-card">
                    <div class="pd-tags-row mb-3">
                        <% if (product.category) { %>
                            <span class="pd-tag pd-tag--category"><%= product.category %></span>
                        <% } %>
                        <% if (productOccasions && productOccasions.length) { %>
                            <% productOccasions.forEach(function(occ){ %>
                                <span class="pd-tag pd-tag--occasion"><%= occ.name %></span>
                            <% }); %>
                        <% } else if (product.occasion) { %>
                            <span class="pd-tag pd-tag--occasion"><%= product.occasion %></span>
                        <% } %>
                    </div>
                    <!-- Product name shown only once in hero -->
                    
                    <div class="price-section mb-4 pd-price-row">
                        <div class="pd-price-top">
                            <span class="current-price">Rs. <%= product.price.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span>
                            <% if (product.discount_percentage && product.discount_percentage > 0) { %>
                                <span class="discount-badge"><%= product.discount_percentage %>% OFF</span>
                            <% } %>
                        </div>
                        <% if (product.original_price && Number(product.original_price) > 0) { %>
                            <div class="pd-mrp-row">
                                <span class="pd-mrp-label">MRP</span>
                                <span class="original-price">Rs. <%= Number(product.original_price).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Rating moved to hero (right side of title) -->
                    
                    <div class="pd-stock-info">
                        <span class="pd-stock-dot <%= product.stock > 0 ? 'on' : '' %>"></span>
                        <span>
                            <%= product.stock > 0 ? `${product.stock} in stock – order soon` : 'Currently out of stock' %>
                        </span>
                    </div>
                    
                    <div class="pd-desc">
                        <h6>What’s inside</h6>
                        <p class="text-muted"><%= product.description %></p>
                    </div>
                    
                    <% /* QR code section removed as per latest requirement */ %>
                    
                    <% if (product.stock > 0) { %>
                        <% if (typeof userId !== 'undefined' && userId) { %>
                            <form action="/cart/add" method="POST" class="pd-buy-form" id="addToCartForm">
                                <%- include('../partials/csrf-token') %>
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <input type="hidden" name="quantity" value="1" id="quantityInput">
                                <div class="pd-qty-row">
                                    <label class="form-label fw-bold mb-2">Quantity</label>
                                    <div class="quantity-controls">
                                        <button type="button" class="quantity-btn" onclick="decreaseQuantity(<%= product.stock %>)" aria-label="Decrease quantity">-</button>
                                        <input type="number" class="quantity-display" value="1" min="1" max="<%= product.stock %>" id="quantityDisplay" readonly>
                                        <button type="button" class="quantity-btn" onclick="increaseQuantity(<%= product.stock %>)" aria-label="Increase quantity">+</button>
                                    </div>
                                </div>
                                <div class="pd-cta-row">
                                    <button type="submit" class="btn btn-gradient-modern btn-lg w-100 py-3 pd-add-btn">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </div>
                            </form>
                        <% } else { %>
                            <div class="alert alert-info mb-3">
                                <i class="bi bi-info-circle"></i> Please <a href="#" class="js-open-auth-login" style="color: var(--veera-red); font-weight: 600;">login</a> or <a href="#" class="js-open-auth-register" style="color: var(--veera-red); font-weight: 600;">create an account</a> to add items to cart and place orders.
                            </div>
                            <a href="#" class="pd-login-btn js-open-auth-login">
                                <i class="bi bi-box-arrow-in-right"></i> Login to Order
                            </a>
                        <% } %>
                    <% } else { %>
                        <button class="btn btn-secondary btn-lg w-100 py-3" disabled>Out of Stock</button>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="row mt-5 pd-reviews-wrap">
        <div class="col-12">
            <% const hasReviews = reviews && reviews.length > 0; %>
            <% if (hasReviews) { %>
                <div class="reviews-section-header mb-4">
                    <h3 class="reviews-title">Customer Reviews</h3>
                    <% if (avgRating > 0) { %>
                        <div class="rating-summary-card">
                            <div class="d-flex align-items-center flex-wrap gap-3">
                                <div class="rating-display">
                                    <div class="rating-number"><%= avgRating %></div>
                                    <div class="rating-out-of">out of 5</div>
                                </div>
                                <div class="rating-stars" aria-label="Average rating stars">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <span class="rating-star <%= i <= Math.round(avgRating) ? 'on' : '' %>">★</span>
                                    <% } %>
                                </div>
                                <div class="rating-count">
                                    <span>Based on <strong><%= totalRatings || 0 %></strong> <%= totalRatings === 1 ? 'review' : 'reviews' %></span>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
            
            <% if (typeof canReview !== 'undefined' && canReview) { %>
                <div class="review-form-card mb-4">
                    <div class="review-form-head">
                        <div>
                            <div class="review-form-kicker">Share your experience</div>
                            <div class="review-form-title">Add a Review</div>
                        </div>
                        <div class="review-form-hint">Your rating helps others choose better.</div>
                    </div>
                    <div class="review-form-body">
                        <form action="/products/<%= product.id %>/review" method="POST" class="review-form">
                            <%- include('../partials/csrf-token') %>
                            <div class="mb-3">
                                <label class="form-label">Rating <span class="text-danger">*</span></label>
                                <div class="star-rating-input mb-2" data-rating-label>
                                    <% for (let i = 5; i >= 1; i--) { %>
                                        <input type="radio" name="rating" id="rating-<%= product.id %>-<%= i %>" value="<%= i %>" required>
                                        <label for="rating-<%= product.id %>-<%= i %>" class="star-label">
                                            <span class="star-char">★</span>
                                        </label>
                                    <% } %>
                                </div>
                                <div class="review-rating-meta">
                                    <span class="review-rating-text">Click stars to rate</span>
                                    <span class="review-rating-selected" id="selectedRatingText-<%= product.id %>">No rating selected</span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="message" class="form-label">Review</label>
                                <textarea class="form-control review-textarea" id="message" name="message" rows="4" placeholder="What did you like? How was the quality, packaging, and delivery? (Optional)"></textarea>
                            </div>
                            <button type="submit" class="btn btn-gradient-modern review-submit-btn" style="color: white !important; border: none;">
                                Submit Review
                            </button>
                        </form>
                    </div>
                </div>
            <% } %>
            
            <% if (hasReviews) { %>
                <div class="reviews-list mt-4">
                    <% reviews.forEach(review => { %>
                        <% const isMe = (typeof userId !== 'undefined' && userId && review.user_id && String(review.user_id) === String(userId)); %>
                        <div class="review-card mb-3 <%= isMe ? 'review-card--me' : '' %>">
                            <div class="review-header">
                                <div class="reviewer-info">
                                    <div class="reviewer-avatar">
                                        <span><%= (review.user_name || '').charAt(0).toUpperCase() %></span>
                                    </div>
                                    <div class="reviewer-details">
                                        <h6 class="reviewer-name mb-0">
                                            <%= review.user_name %>
                                            <% if (isMe) { %><span class="reviewer-me">(Me)</span><% } %>
                                        </h6>
                                        <small class="review-date text-muted">
                                            <i class="bi bi-calendar3"></i>
                                            <%= new Date(review.created_at).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                        </small>
                                    </div>
                                </div>
                                <div class="review-rating">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <span class="review-star <%= i <= review.rating ? 'on' : '' %>">★</span>
                                    <% } %>
                                </div>
                            </div>
                            <% if (review.message) { %>
                                <div class="review-message mt-3">
                                    <p class="mb-0"><%= review.message %></p>
                                </div>
                            <% } %>

                            <% if (isMe) { %>
                                <div class="review-actions">
                                    <button type="button" class="review-edit-btn" data-review-id="<%= review.id %>">Edit</button>
                                </div>
                                <div class="review-edit-wrap" id="reviewEditWrap-<%= review.id %>" style="display:none;">
                                    <form action="/products/<%= product.id %>/review" method="POST" class="review-edit-form">
                                        <%- include('../partials/csrf-token') %>
                                        <div class="mb-2">
                                            <label class="form-label small mb-1">Update rating</label>
                                            <div class="star-rating-input mb-2">
                                                <% for (let i = 5; i >= 1; i--) { %>
                                                    <input type="radio" name="rating" id="edit-rating-<%= review.id %>-<%= i %>" value="<%= i %>" <%= Number(review.rating) === i ? 'checked' : '' %> required>
                                                    <label for="edit-rating-<%= review.id %>-<%= i %>" class="star-label">
                                                        <span class="star-char">★</span>
                                                    </label>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label small mb-1" for="edit-message-<%= review.id %>">Update review</label>
                                            <textarea class="form-control review-textarea" id="edit-message-<%= review.id %>" name="message" rows="4"><%= review.message || '' %></textarea>
                                        </div>
                                        <div class="review-edit-cta">
                                            <button type="submit" class="review-save-btn">Save</button>
                                            <button type="button" class="review-cancel-btn" data-review-id="<%= review.id %>">Cancel</button>
                                        </div>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<style>
    /* Quantity Controls Styling for Product Details */
    .quantity-controls {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        max-width: 220px;
    }
    .quantity-btn {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        font-size: 1.4rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #dee2e6;
        background: #fff;
        color: #1c1008;
        transition: all 0.2s ease;
        cursor: pointer;
        flex-shrink: 0;
        padding: 0;
    }
    .quantity-btn:hover {
        background: var(--veera-accent);
        border-color: var(--veera-accent);
        color: #fff;
        transform: translateY(-1px);
    }
    .quantity-btn:active {
        transform: translateY(0);
    }
    .quantity-btn i {
        font-size: 1.3rem;
        line-height: 1;
    }
    .quantity-display {
        flex: 1;
        max-width: 90px;
        min-width: 70px;
        height: 42px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        text-align: center;
        border: 2px solid #dee2e6;
        background: #f8f9fa;
        padding: 0.25rem 0.5rem;
    }
    .quantity-display:focus {
        outline: none;
        border-color: var(--veera-accent);
        box-shadow: 0 0 0 0.16rem rgba(212, 165, 116, 0.25);
    }

    /* Buy form spacing */
    .pd-buy-form{
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .pd-qty-row{
        margin: 0;
        padding: 0;
    }
    .pd-cta-row{
        margin-top: 2px;
        padding-bottom: 6px;
    }
</style>

<script>
    // Quantity control functions for product details page
    function increaseQuantity(maxStock) {
        const display = document.getElementById('quantityDisplay');
        const input = document.getElementById('quantityInput');
        if (display && input) {
            let currentValue = parseInt(display.value) || 1;
            if (currentValue < maxStock) {
                currentValue++;
                display.value = currentValue;
                input.value = currentValue;
            }
        }
    }
    
    function decreaseQuantity(maxStock) {
        const display = document.getElementById('quantityDisplay');
        const input = document.getElementById('quantityInput');
        if (display && input) {
            let currentValue = parseInt(display.value) || 1;
            if (currentValue > 1) {
                currentValue--;
                display.value = currentValue;
                input.value = currentValue;
            }
        }
    }
</script>

