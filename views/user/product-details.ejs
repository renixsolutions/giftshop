        font-size: 0.95rem;
        padding-top: 1rem;
        border-top: 1px solid #f0f0f0;
    }
    
    .review-message p {
        margin: 0;
        color: #555;
    }
    
    .no-reviews-card {
        background: #f8f9fa;
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 3rem 1rem;
    }
    
    /* GiftHouse‑style detail layout */
    .pd-hero {
        background: var(--warm);
        border-bottom: 1px solid var(--border);
        padding: 28px 48px 20px;
    }
