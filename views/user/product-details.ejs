    }
    
    .rating-number {
        font-size: 2rem;
        font-weight: 700;
        color: var(--veera-accent-dark);
        line-height: 1;
    }
    
    .rating-out-of {
        font-size: 0.9rem;
        color: #666;
        font-weight: 500;
    }
    
    .rating-stars {
        display: flex;
        gap: 2px;
    }
    
    .rating-count {
        margin-left: auto;
        font-size: 0.9rem;
        color:#555;
    }
    
    .no-rating-message {
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
        border-left: 3px solid var(--veera-accent);
    }
    
    .reviews-list {
        margin-top: 2rem;
    }
    
    .review-card {
