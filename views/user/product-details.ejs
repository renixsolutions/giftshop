<script>
    // Star rating hover effect for product details page
    document.addEventListener('DOMContentLoaded', function() {
        // Review edit toggles (only for "Me" review)
        document.querySelectorAll('.review-edit-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.getAttribute('data-review-id');
                const wrap = document.getElementById('reviewEditWrap-' + id);
                if (wrap) wrap.style.display = 'block';
                this.style.display = 'none';
            });
        });
        document.querySelectorAll('.review-cancel-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.getAttribute('data-review-id');
                const wrap = document.getElementById('reviewEditWrap-' + id);
                if (wrap) wrap.style.display = 'none';
                const editBtn = document.querySelector('.review-edit-btn[data-review-id="' + id + '"]');
                if (editBtn) editBtn.style.display = 'inline-flex';
            });
        });

        document.querySelectorAll('.star-rating-input').forEach(container => {
            const labels = container.querySelectorAll('.star-label');
            const inputs = container.querySelectorAll('input[type="radio"]');
            const selectedText = (function(){
                // Find nearby "selected rating" pill
                const wrap = container.closest('.review-form') || container.parentElement;
                if (!wrap) return null;
                return wrap.querySelector('.review-rating-selected');
            })();
            
            labels.forEach((label, index) => {
                label.addEventListener('mouseenter', function() {
                    const rating = 5 - index;
                    labels.forEach((l, i) => {
                        if (5 - i <= rating) {
                            l.style.color = '#ffc107';
                        } else {
                            l.style.color = '#ddd';
                        }
                    });
                });
            });
            
            container.addEventListener('mouseleave', function() {
                const checkedInput = container.querySelector('input[type="radio"]:checked');
                labels.forEach((label, index) => {
                    if (checkedInput) {
                        const checkedRating = parseInt(checkedInput.value);
                        const labelRating = 5 - index;
                        if (labelRating <= checkedRating) {
                            label.style.color = '#ffc107';
                        } else {
                            label.style.color = '#ddd';
                        }
                    } else {
                        label.style.color = '#ddd';
                    }
                });
            });
            
            inputs.forEach(input => {
                input.addEventListener('change', function() {
                    const rating = parseInt(this.value);
                    labels.forEach((label, index) => {
                        const labelRating = 5 - index;
                        if (labelRating <= rating) {
                            label.style.color = '#ffc107';
                        } else {
                            label.style.color = '#ddd';
                        }
                    });
                    if (selectedText) {
                        selectedText.textContent = rating + ' / 5 selected';
                    }
                });
            });

            // Initial state (if browser restores form or on back navigation)
            const checked = container.querySelector('input[type="radio"]:checked');
            if (checked && selectedText) selectedText.textContent = parseInt(checked.value) + ' / 5 selected';
        });
    });
</script>

