        }
        .card.mb-4 .card-body{
            padding:16px 14px;
        }
        .card.mb-4 textarea.form-control{
            font-size:13px;
            min-height:90px;
            border-radius:10px;
        }
        .card.mb-4 button.btn.btn-gradient-modern{
            width:100%;
            border-radius:999px;
        }
    }
    
    /* Breadcrumb Styling */
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-bottom: 1.5rem;
