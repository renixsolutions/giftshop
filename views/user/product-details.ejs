    /* Review form card */
    .review-form-card{
        border-radius: 18px;
        overflow:hidden;
        border: 1px solid rgba(28,16,8,.10);
        background: #fff;
        box-shadow: 0 10px 26px rgba(28,16,8,.08);
    }
    .review-form-head{
        padding: 16px 18px;
        background: linear-gradient(135deg, rgba(196,98,45,.10), rgba(255,255,255,0));
        border-bottom: 1px solid rgba(28,16,8,.08);
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap:10px;
        flex-wrap:wrap;
    }
    .review-form-kicker{
        font-size: 11px;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: rgba(196,98,45,.9);
    }
    .review-form-title{
        font-family:'Playfair Display',serif;
        font-weight:800;
        font-size: 20px;
        color: var(--ink);
