<%- include('../partials/header-gift') %>
<%- include('../partials/navbar-gift', { 
  currentPage: 'catalog',
  cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
  userId: typeof userId !== 'undefined' ? userId : null 
}) %>

<div class="pd-hero">
    <div class="pd-hero-inner">
        <div>
            <div class="pd-breadcrumb">
                <a href="/">Home</a>
                <span>›</span>
                <a href="/collections">Collections</a>
                <span>›</span>
                <span><%= product.title %></span>
            </div>
            <h1 class="pd-title"><%= product.title %></h1>
            <p class="pd-sub">
                Thoughtfully curated gift, beautifully packed and ready to delight.
            </p>
            <% if (avgRating && avgRating > 0) { %>
            <div class="pd-hero-rating">
                <div class="pd-hero-stars">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <span class="pd-star <%= i <= Math.round(avgRating) ? 'pd-star--on' : '' %>">★</span>
                    <% } %>
                </div>
                <div class="pd-hero-rating-meta">
                    <span class="pd-hero-rating-val"><%= avgRating %></span>
                    <span class="pd-hero-rating-text">· <%= totalRatings || 0 %> <%= totalRatings === 1 ? 'review' : 'reviews' %></span>
                </div>
            </div>
            <% } %>
        </div>
        <div class="pd-meta-pill">
            <span class="pd-meta-label">Price</span>
            <span class="pd-meta-value">
                Rs. <%= product.price.toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
            </span>
        </div>
    </div>
</div>

<div class="pd-shell">
    <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
            <%= flash.message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="pd-main">
        <div class="pd-left">
            <div class="pd-image-card">
                <img
                    src="<%= product.image || '' %>"
                    alt="<%= product.title %>"
                    class="pd-image"
                    onerror="this.onerror=null; this.src='data:image/svg+xml;base64,';"
                >
            </div>
            
            <% if (galleryImages && galleryImages.length > 0) { %>
            <div class="pd-thumbs">
                <% galleryImages.forEach(function(img) { %>
                    <button type="button" class="pd-thumb" onclick="document.querySelector('.pd-image').src='<%= img.image_url %>'">
                        <img src="<%= img.image_url %>" alt="" onerror="this.style.display='none'">
                    </button>
                <% }); %>
            </div>
            <% } %>
        </div>

        <div class="pd-right">
            <div class="pd-summary-card">
                    <div class="pd-tags-row mb-3">
                        <% if (product.category) { %>
                            <span class="pd-tag pd-tag--category"><%= product.category %></span>
                        <% } %>
                        <% if (productOccasions && productOccasions.length) { %>
                            <% productOccasions.forEach(function(occ){ %>
                                <span class="pd-tag pd-tag--occasion"><%= occ.name %></span>
                            <% }); %>
                        <% } else if (product.occasion) { %>
                            <span class="pd-tag pd-tag--occasion"><%= product.occasion %></span>
                        <% } %>
                    </div>
                    <h2 class="pd-summary-title"><%= product.title %></h2>
                    
                    <div class="price-section mb-4 pd-price-row">
                        <% if (product.original_price && product.original_price > product.price) { %>
                            <span class="original-price">Rs. <%= product.original_price.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span>
                        <% } %>
                        <div class="mt-2">
                            <span class="current-price">Rs. <%= product.price.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></span>
                            <% if (product.discount_percentage && product.discount_percentage > 0) { %>
                                <span class="discount-badge"><%= product.discount_percentage %>% OFF</span>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Rating Display -->
                    <div class="mb-4">
                        <% if (avgRating > 0) { %>
                            <div class="pd-rating-card">
                                <div>
                                    <div class="pd-rating-num"><%= avgRating %></div>
                                    <div class="pd-rating-denom">out of 5</div>
                                </div>
                                <div class="pd-rating-info">
                                    <div class="pd-rating-mini-stars">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <span class="<%= i <= Math.round(avgRating) ? 'on' : '' %>">★</span>
                                        <% } %>
                                    </div>
                                    <p>Based on <%= totalRatings || 0 %> <%= totalRatings === 1 ? 'rating' : 'ratings' %></p>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="no-rating-message">
                                <p class="text-muted mb-0">
                                    <i class="bi bi-info-circle"></i> No ratings yet. Be the first to review this product!
                                </p>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="mb-4 pd-stock-info">
                        <span class="pd-stock-dot <%= product.stock > 0 ? 'on' : '' %>"></span>
                        <span>
                            <%= product.stock > 0 ? `${product.stock} in stock – order soon` : 'Currently out of stock' %>
                        </span>
                    </div>
                    
                    <div class="mb-4 pd-desc">
                        <h6>What’s inside</h6>
                        <p class="text-muted"><%= product.description %></p>
                    </div>
                    
                    <% /* QR code section removed as per latest requirement */ %>
                    
                    <% if (product.stock > 0) { %>
                        <% if (typeof userId !== 'undefined' && userId) { %>
                            <form action="/cart/add" method="POST" class="mb-4" id="addToCartForm">
                                <%- include('../partials/csrf-token') %>
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <input type="hidden" name="quantity" value="1" id="quantityInput">
                                <div class="mb-4">
                                    <label class="form-label fw-bold mb-2">Quantity</label>
                                    <div class="quantity-controls">
                                        <button type="button" class="quantity-btn" onclick="decreaseQuantity(<%= product.stock %>)">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <input type="number" class="quantity-display" value="1" min="1" max="<%= product.stock %>" id="quantityDisplay" readonly>
                                        <button type="button" class="quantity-btn" onclick="increaseQuantity(<%= product.stock %>)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button type="submit" class="btn btn-gradient-modern btn-lg w-100 py-3 pd-add-btn">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </div>
                            </form>
                        <% } else { %>
                            <div class="alert alert-info mb-3">
                                <i class="bi bi-info-circle"></i> Please <a href="#" class="js-open-auth-login" style="color: var(--veera-red); font-weight: 600;">login</a> or <a href="#" class="js-open-auth-register" style="color: var(--veera-red); font-weight: 600;">create an account</a> to add items to cart and place orders.
                            </div>
                            <a href="#" class="pd-login-btn js-open-auth-login">
                                <i class="bi bi-box-arrow-in-right"></i> Login to Order
                            </a>
                        <% } %>
                    <% } else { %>
                        <button class="btn btn-secondary btn-lg w-100 py-3" disabled>Out of Stock</button>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="reviews-section-header mb-4">
                <h3 class="reviews-title">
                    Customer Reviews
                </h3>
                <% if (avgRating > 0) { %>
                    <div class="rating-summary-card">
                        <div class="d-flex align-items-center flex-wrap gap-3">
                            <div class="rating-display">
                                <div class="rating-number"><%= avgRating %></div>
                                <div class="rating-out-of">out of 5</div>
                            </div>
                            <div class="rating-stars">
                                <% for (let i = 1; i <= 5; i++) { %>
                                    <i class="bi bi-star<%= i <= Math.round(avgRating) ? '-fill' : '' %> <%= i <= Math.round(avgRating) ? 'text-warning' : 'text-muted' %>"></i>
                                <% } %>
                            </div>
                            <div class="rating-count">
                                <span>Based on <strong><%= totalRatings || 0 %></strong> <%= totalRatings === 1 ? 'review' : 'reviews' %></span>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="no-rating-message">
                        <p class="text-muted mb-0">
                            <i class="bi bi-info-circle"></i> No reviews yet. Be the first to review this product!
                        </p>
                    </div>
                <% } %>
            </div>
            
            <% if (typeof userId !== 'undefined' && userId) { %>
                <div class="card mb-4">
                    <div class="card-body">
                        <h5>Add a Review</h5>
                        <form action="/products/<%= product.id %>/review" method="POST">
                            <%- include('../partials/csrf-token') %>
                            <div class="mb-3">
                                <label class="form-label">Rating <span class="text-danger">*</span></label>
                                <div class="star-rating-input mb-2">
                                    <% for (let i = 5; i >= 1; i--) { %>
                                        <input type="radio" name="rating" id="rating-<%= product.id %>-<%= i %>" value="<%= i %>" required>
                                        <label for="rating-<%= product.id %>-<%= i %>" class="star-label">
                                            <i class="bi bi-star-fill"></i>
                                        </label>
                                    <% } %>
                                </div>
                                <small class="text-muted">Click on a star to rate</small>
                            </div>
                            <div class="mb-3">
                                <label for="message" class="form-label">Review</label>
                                <textarea class="form-control" id="message" name="message" rows="3" placeholder="Share your experience with this product... (Optional)"></textarea>
                            </div>
                            <button type="submit" class="btn btn-gradient-modern" style="color: white !important; border: none;">
                                <i class="bi bi-star-fill"></i> Submit Review
                            </button>
                        </form>
                    </div>
                </div>
            <% } %>
            
            <div class="reviews-list mt-4">
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach(review => { %>
                        <div class="review-card mb-3">
                            <div class="review-header">
                                <div class="reviewer-info">
                                    <div class="reviewer-avatar">
                                        <span><%= (review.user_name || '').charAt(0).toUpperCase() %></span>
                                    </div>
                                    <div class="reviewer-details">
                                        <h6 class="reviewer-name mb-0"><%= review.user_name %></h6>
                                        <small class="review-date text-muted">
                                            <i class="bi bi-calendar3"></i>
                                            <%= new Date(review.created_at).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                        </small>
                                    </div>
                                </div>
                                <div class="review-rating">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <i class="bi bi-star<%= i <= review.rating ? '-fill' : '' %> <%= i <= review.rating ? 'text-warning' : 'text-muted' %>"></i>
                                    <% } %>
                                </div>
                            </div>
                            <% if (review.message) { %>
                                <div class="review-message mt-3">
                                    <p class="mb-0"><%= review.message %></p>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>
</div>

<style>
    /* Quantity Controls Styling for Product Details */
    .quantity-controls {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        max-width: 220px;
    }
    .quantity-btn {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        font-size: 1.4rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #dee2e6;
        background: #fff;
        color: var(--veera-text);
        transition: all 0.2s ease;
        cursor: pointer;
        flex-shrink: 0;
        padding: 0;
    }
    .quantity-btn:hover {
        background: var(--veera-accent);
        border-color: var(--veera-accent);
        color: #fff;
        transform: translateY(-1px);
    }
    .quantity-btn:active {
        transform: translateY(0);
    }
    .quantity-btn i {
        font-size: 1.3rem;
        line-height: 1;
    }
    .quantity-display {
        flex: 1;
        max-width: 90px;
        min-width: 70px;
        height: 42px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        text-align: center;
        border: 2px solid #dee2e6;
        background: #f8f9fa;
        padding: 0.25rem 0.5rem;
    }
    .quantity-display:focus {
        outline: none;
        border-color: var(--veera-accent);
        box-shadow: 0 0 0 0.16rem rgba(212, 165, 116, 0.25);
    }
</style>

<script>
    // Quantity control functions for product details page
    function increaseQuantity(maxStock) {
        const display = document.getElementById('quantityDisplay');
        const input = document.getElementById('quantityInput');
        if (display && input) {
            let currentValue = parseInt(display.value) || 1;
            if (currentValue < maxStock) {
                currentValue++;
                display.value = currentValue;
                input.value = currentValue;
            }
        }
    }
    
    function decreaseQuantity(maxStock) {
        const display = document.getElementById('quantityDisplay');
        const input = document.getElementById('quantityInput');
        if (display && input) {
            let currentValue = parseInt(display.value) || 1;
            if (currentValue > 1) {
                currentValue--;
                display.value = currentValue;
                input.value = currentValue;
            }
        }
    }
</script>

<style>
    .pd-add-btn{
        border-radius:12px;
        font-weight:600;
        letter-spacing:.04em;
        box-shadow:0 8px 20px rgba(28,16,8,.18);
        border:none;
    }
    .pd-add-btn:hover{
        transform:translateY(-1px);
        box-shadow:0 10px 26px rgba(28,16,8,.24);
    }

    /* Star Rating Input Styling */
    .star-rating-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 8px;
    }
    .star-rating-input input[type="radio"] {
        display: none;
    }
    .star-rating-input .star-label {
        cursor: pointer;
        font-size: 2rem;
        color: #ddd;
        transition: color 0.2s ease, transform 0.1s ease;
    }
    .star-rating-input .star-label:hover,
    .star-rating-input .star-label:hover ~ .star-label {
        color: #ffc107;
        transform: scale(1.1);
    }
    .star-rating-input input[type="radio"]:checked ~ .star-label,
    .star-rating-input input[type="radio"]:checked + .star-label {
        color: #ffc107;
    }
    .star-rating-input input[type="radio"]:checked ~ .star-label {
        color: #ffc107;
    }
    
    @media (max-width: 768px) {
        .star-rating-input .star-label {
            font-size: 1.5rem;
        }
        .reviews-section-header{
            margin-top:16px;
        }
        .card.mb-4 .card-body{
            padding:16px 14px;
        }
        .card.mb-4 textarea.form-control{
            font-size:13px;
            min-height:90px;
            border-radius:10px;
        }
        .card.mb-4 button.btn.btn-gradient-modern{
            width:100%;
            border-radius:999px;
        }
    }
    
    /* Breadcrumb Styling */
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
    }
    
    .breadcrumb-item {
        color: var(--veera-gray);
    }
    
    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        color: var(--veera-gray);
        padding: 0 0.5rem;
    }
    
    .breadcrumb-item a {
        color: var(--veera-accent-dark);
        text-decoration: none !important;
        transition: color 0.2s ease;
    }
    
    .breadcrumb-item a:hover {
        color: var(--veera-accent);
        text-decoration: none !important;
    }
    
    .breadcrumb-item.active {
