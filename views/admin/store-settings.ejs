<%- include('../partials/header') %>

<div class="admin-layout">
    <%- include('../partials/admin-sidebar', { currentPage: 'settings' }) %>
    
    <div class="admin-main">
        <%- include('../partials/admin-header', { pageTitle: 'Store Settings' }) %>
        
        <div class="admin-content">
            <% if (typeof flash !== 'undefined' && flash) { %>
                <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
                    <%= flash.message %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            
            <div class="admin-card">
                <h4 class="mb-4"><i class="bi bi-gear"></i> Store Settings</h4>
                
                <form action="/admin/settings" method="POST" id="settingsForm">
                    <%- include('../partials/csrf-token') %>
                    
                    <div class="row">
                        <div class="col-md-8">
                            <div class="card mb-4">
                                <div class="card-header bg-warning text-dark">
                                    <strong><i class="bi bi-pause-circle"></i> Pause Orders Mode</strong>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted">Use this feature if you are overwhelmed with orders and need to temporarily stop taking new ones. When enabled, users will see a message instead of the checkout page.</p>
                                    
                                    <div class="form-check form-switch mb-4">
                                        <input class="form-check-input" type="checkbox" id="enabled" name="enabled" <%= pauseSettings.enabled ? 'checked' : '' %>>
                                        <label class="form-check-label h5" for="enabled">Enable "Pause Orders" Mode</label>
                                    </div>
                                    
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label for="startDate" class="form-label">Start Time (Optional)</label>
                                            <input type="datetime-local" class="form-control" id="startDate" name="startDate" value="<%= pauseSettings.startDateLocal || '' %>">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="endDate" class="form-label">End Time (Optional)</label>
                                            <input type="datetime-local" class="form-control" id="endDate" name="endDate" value="<%= pauseSettings.endDateLocal || '' %>">
                                            <small class="text-muted">Orders will automatically resume after this time.</small>
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="message" class="form-label">Message Displayed to Customers</label>
                                        <textarea class="form-control" id="message" name="message" rows="3" required><%= pauseSettings.message %></textarea>
                                        <small class="text-muted">Example: Sorry, we are currently facing high demand bulk orders so at the moment we are not taking any orders.</small>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save"></i> Save Settings
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Sidebar toggle
    document.getElementById('mobileSidebarToggle')?.addEventListener('click', function() {
        document.getElementById('sidebar').classList.toggle('active');
        document.getElementById('sidebarOverlay').classList.toggle('active');
    });
    
    document.getElementById('sidebarToggle')?.addEventListener('click', function() {
        document.getElementById('sidebar').classList.remove('active');
        document.getElementById('sidebarOverlay').classList.remove('active');
    });
    
    document.getElementById('sidebarOverlay')?.addEventListener('click', function() {
        document.getElementById('sidebar').classList.remove('active');
        this.classList.remove('active');
    });
</script>
</body>
</html>
