<%- include('../partials/header') %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { currentPage: 'occasions' }) %>

  <div class="admin-main">
    <%- include('../partials/admin-header', { pageTitle: 'Manage Occasions' }) %>

    <div class="admin-content">
      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
          <%= flash.message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <h2 class="mb-0">Occasions</h2>
        <a href="/admin/occasions/new" class="btn btn-primary">
          <i class="bi bi-plus-circle"></i> <span class="d-none d-sm-inline">Add Occasion</span><span class="d-sm-none">Add</span>
        </a>
      </div>

      <div class="admin-card">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Slug</th>
                <th>Status</th>
                <th>Sort</th>
                <th>Products</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (occasions && occasions.length > 0) { %>
                <% occasions.forEach(function(occ) { %>
                  <tr>
                    <td><strong><%= occ.id %></strong></td>
                    <td>
                      <div class="fw-semibold"><%= occ.name %></div>
                      <% if (occ.description) { %>
                        <small class="text-muted"><%= occ.description.substring(0, 60) %><%= occ.description.length > 60 ? '…' : '' %></small>
                      <% } %>
                    </td>
                    <td><code><%= occ.slug %></code></td>
                    <td>
                      <span class="badge bg-<%= occ.is_active ? 'success' : 'secondary' %>">
                        <%= occ.is_active ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td><%= occ.sort_order %></td>
                    <td>
                      <span class="badge bg-info text-dark"><%= occ.productCount || 0 %></span>
                    </td>
                    <td>
                      <div class="btn-group" role="group">
                        <a href="/admin/occasions/<%= occ.id %>/edit" class="btn btn-sm btn-warning">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form action="/admin/occasions/<%= occ.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this occasion?');">
                          <%- include('../partials/csrf-token') %>
                          <button type="submit" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: #ddd;"></i>
                    <p class="text-muted mt-3 mb-0">No occasions found. <a href="/admin/occasions/new">Create your first occasion</a></p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>

