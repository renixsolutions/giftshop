<%- include('../partials/header') %>

<div class="admin-layout">
    <%- include('../partials/admin-sidebar', { currentPage: 'orders' }) %>
    
    <div class="admin-main">
        <%- include('../partials/admin-header', { pageTitle: 'Manage Orders' }) %>
        
        <div class="admin-content">
            <% if (typeof flash !== 'undefined' && flash) { %>
                <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
                    <%= flash.message %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <h2 class="mb-0 fw-bold" style="font-family: 'Playfair Display', serif;">Orders</h2>
                <div class="d-flex gap-2 overflow-auto pb-1" style="white-space: nowrap; -webkit-overflow-scrolling: touch; scrollbar-width: none;">
                    <a href="/admin/orders" class="btn rounded-pill px-3 py-1 btn-sm <%= !req.query.status || req.query.status === 'all' ? 'btn-dark' : 'btn-outline-secondary text-dark border-opacity-50' %>" style="font-weight: 500;">All</a>
                    <a href="/admin/orders?status=pending" class="btn rounded-pill px-3 py-1 btn-sm <%= req.query.status === 'pending' ? 'btn-warning text-dark' : 'btn-outline-secondary text-dark border-opacity-50' %>" style="font-weight: 500;">Pending</a>
                    <a href="/admin/orders?status=processing" class="btn rounded-pill px-3 py-1 btn-sm <%= req.query.status === 'processing' ? 'btn-info text-dark' : 'btn-outline-secondary text-dark border-opacity-50' %>" style="font-weight: 500;">Processing</a>
                    <a href="/admin/orders?status=shipped" class="btn rounded-pill px-3 py-1 btn-sm <%= req.query.status === 'shipped' ? 'btn-primary' : 'btn-outline-secondary text-dark border-opacity-50' %>" style="font-weight: 500;">Shipped</a>
                    <a href="/admin/orders?status=delivered" class="btn rounded-pill px-3 py-1 btn-sm <%= req.query.status === 'delivered' ? 'btn-success' : 'btn-outline-secondary text-dark border-opacity-50' %>" style="font-weight: 500;">Delivered</a>
                </div>
                <style>.overflow-auto::-webkit-scrollbar { display: none; }</style>
            </div>
            
            <!-- Desktop Table View -->
            <div class="admin-table d-none d-md-block">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th class="d-none d-md-table-cell">Email</th>
                                <th class="d-none d-lg-table-cell">Address</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th class="d-none d-lg-table-cell">Desired delivery</th>
                                <th class="d-none d-lg-table-cell">Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (orders && orders.length > 0) { %>
                                <% orders.forEach(order => { %>
                                    <tr>
                                        <td><strong>#<%= order.id %></strong></td>
                                        <td>
                                            <%= order.user_name %>
                                            <% if (order.customer_phone) { %>
                                                <br><small class="text-muted"><i class="bi bi-telephone"></i> <%= order.customer_phone %></small>
                                            <% } %>
                                        </td>
                                        <td class="d-none d-md-table-cell"><%= order.user_email %></td>
                                        <td class="d-none d-lg-table-cell">
                                            <% if (order.shipping_address) { %>
                                                <small>
                                                    <%= order.shipping_address %><br>
                                                    <%= order.city || '' %><%= order.city && order.state ? ', ' : '' %><%= order.state || '' %>
                                                    <% if (order.pincode) { %> - <%= order.pincode %><% } %>
                                                </small>
                                            <% } else { %>
                                                <span class="text-muted">-</span>
                                            <% } %>
                                        </td>
                                        <td><strong>₹<%= order.total_amount.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></strong></td>
                                        <td>
                                            <span class="badge bg-<%= 
                                                order.status === 'delivered' ? 'success' : 
                                                order.status === 'cancelled' ? 'danger' : 
                                                order.status === 'shipped' ? 'info' : 
                                                order.status === 'processing' ? 'primary' : 'warning' 
                                            %>">
                                                <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                                            </span>
                                        </td>
                                        <td class="d-none d-lg-table-cell"><%= order.delivery_date ? new Date(order.delivery_date).toLocaleDateString() : '-' %></td>
                                        <td class="d-none d-lg-table-cell"><%= new Date(order.created_at).toLocaleDateString() %></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <a href="/admin/orders/<%= order.id %>" class="btn btn-sm btn-outline-secondary" title="View Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <form action="/admin/orders/<%= order.id %>/status" method="POST" class="m-0">
                                                    <%- include('../partials/csrf-token') %>
                                                    <select name="status" class="form-select form-select-sm" style="min-width: 125px; cursor: pointer;" onchange="this.form.submit()">
                                                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                                        <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Processing</option>
                                                        <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                                                        <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                                                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                                    </select>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center py-5">
                                        <i class="bi bi-inbox" style="font-size: 3rem; color: #ddd;"></i>
                                        <p class="text-muted mt-3">No orders found</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- Mobile Card View -->
            <div class="d-md-none">
                <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <div class="card mb-3 border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width: 40px; height: 40px; background: #faf9f7; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-box-seam" style="font-size: 20px; color: #8A7060;"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold" style="font-family: 'Playfair Display', serif; font-size: 16px;">Order #<%= order.id %></h6>
                                            <small class="text-muted" style="font-size: 11px;"><i class="bi bi-calendar3"></i> <%= new Date(order.created_at).toLocaleDateString() %></small>
                                        </div>
                                    </div>
                                    <span class="badge bg-<%= 
                                        order.status === 'delivered' ? 'success' : 
                                        order.status === 'cancelled' ? 'danger' : 
                                        order.status === 'shipped' ? 'info' : 
                                        order.status === 'processing' ? 'primary' : 'warning' 
                                    %>" style="font-size: 11px; padding: 5px 8px; border-radius: 6px;">
                                        <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                                    </span>
                                </div>
                                
                                <div class="bg-light rounded p-2 mb-3 mt-3" style="font-size: 13px;">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bi bi-person me-2 text-muted"></i> <strong><%= order.user_name %></strong>
                                    </div>
                                    <% if (order.customer_phone) { %>
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="bi bi-telephone me-2 text-muted"></i> <span class="text-muted"><%= order.customer_phone %></span>
                                        </div>
                                    <% } %>
                                    <% if (order.shipping_address) { %>
                                        <div class="d-flex align-items-start mt-2 pt-2 border-top">
                                            <i class="bi bi-geo-alt me-2 text-muted mt-1"></i>
                                            <div class="text-muted" style="line-height: 1.3;">
                                                <%= order.shipping_address %><br>
                                                <%= order.city || '' %><%= order.city && order.state ? ', ' : '' %><%= order.state || '' %>
                                                <% if (order.pincode) { %> - <%= order.pincode %><% } %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <span class="text-muted" style="font-size: 12px; display: block; margin-bottom: -2px;">Total</span>
                                        <h5 class="fw-bold mb-0" style="color: #C4622D; font-size: 18px;">₹<%= order.total_amount.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></h5>
                                    </div>
                                    <a href="/admin/orders/<%= order.id %>" class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center px-3" style="border-radius: 8px; height: 36px; border-color: #e0e0e0; font-weight: 500;">
                                        <i class="bi bi-eye me-2"></i> View Details
                                    </a>
                                </div>
                                <div class="w-100">
                                    <form action="/admin/orders/<%= order.id %>/status" method="POST" class="m-0 w-100">
                                        <%- include('../partials/csrf-token') %>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0" style="border-radius: 8px 0 0 8px; color: #6c757d;"><i class="bi bi-arrow-repeat"></i></span>
                                            <select name="status" class="form-select border-0 bg-light" style="font-size: 14px; font-weight: 600; cursor: pointer; border-radius: 0 8px 8px 0; height: 38px;" onchange="this.form.submit()">
                                                <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                                <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Processing</option>
                                                <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                                                <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                                                <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                            </select>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="card text-center py-5">
                        <div class="card-body">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #ddd;"></i>
                            <p class="text-muted mt-3">No orders found</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('mobileSidebarToggle')?.addEventListener('click', function() {
        document.getElementById('sidebar').classList.toggle('active');
        document.getElementById('sidebarOverlay').classList.toggle('active');
    });
    
    document.getElementById('sidebarToggle')?.addEventListener('click', function() {
        document.getElementById('sidebar').classList.remove('active');
        document.getElementById('sidebarOverlay').classList.remove('active');
    });
    
    document.getElementById('sidebarOverlay')?.addEventListener('click', function() {
        document.getElementById('sidebar').classList.remove('active');
        this.classList.remove('active');
    });
</script>
</body>
</html>
