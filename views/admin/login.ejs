<%- include('../partials/header') %>
<%- include('../partials/loader') %>

<style>
    :root {
        --brand-accent: #C4622D;
        --brand-ink: #1C1008;
        --brand-warm: #FAF9F7;
        --brand-border: #E8E3DF;
    }
    body {
        background-color: var(--brand-warm);
        font-family: 'Inter', sans-serif;
    }
    
    /* Framer Motion style staggered fade-up animations */
    @keyframes fadeUpSpring {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }
        70% {
            transform: translateY(-2px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-container {
        perspective: 1000px;
    }

    .framer-item {
        opacity: 0;
        animation: fadeUpSpring 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    .framer-delay-1 { animation-delay: 0.1s; }
    .framer-delay-2 { animation-delay: 0.2s; }
    .framer-delay-3 { animation-delay: 0.3s; }
    .framer-delay-4 { animation-delay: 0.4s; }

    /* Polished Card */
    .admin-login-card {
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(28, 16, 8, 0.06), 0 1px 3px rgba(28, 16, 8, 0.02);
        overflow: hidden;
        border: 1px solid rgba(255,255,255, 0.8);
        position: relative;
    }

    /* Ambient Background Glow */
    .ambient-glow {
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(196, 98, 45, 0.05) 0%, rgba(250, 249, 247, 0) 70%);
        border-radius: 50%;
        top: -200px;
        right: -200px;
        z-index: -1;
        pointer-events: none;
    }

    .ambient-glow-2 {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(28, 16, 8, 0.03) 0%, rgba(250, 249, 247, 0) 70%);
        border-radius: 50%;
        bottom: -100px;
        left: -100px;
        z-index: -1;
        pointer-events: none;
    }

    /* Input styling */
    .custom-input-group {
        position: relative;
        margin-bottom: 24px;
    }
    .custom-input {
        width: 100%;
        background: #F5F3F0;
        border: 1.5px solid transparent;
        border-radius: 12px;
        padding: 16px 16px 16px 48px;
        color: var(--brand-ink);
        font-weight: 500;
        font-size: 15px;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        outline: none;
    }
    .custom-input:focus {
        background: #ffffff;
        border-color: var(--brand-accent);
        box-shadow: 0 0 0 4px rgba(196, 98, 45, 0.1);
    }
    .custom-input::placeholder {
        color: #A09A96;
        font-weight: 400;
    }
    .input-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #A09A96;
        font-size: 18px;
        transition: color 0.3s;
        z-index: 2;
    }
    .custom-input:focus ~ .input-icon {
        color: var(--brand-accent);
    }
    .password-toggle {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #A09A96;
        font-size: 18px;
        cursor: pointer;
        z-index: 2;
        transition: color 0.2s;
        background: none;
        border: none;
        padding: 0;
    }
    .password-toggle:hover {
        color: var(--brand-ink);
    }

    /* Modern Button */
    .login-btn {
        background: var(--brand-ink);
        color: #ffffff;
        border: none;
        width: 100%;
        padding: 16px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 16px;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        position: relative;
        overflow: hidden;
    }
    .login-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(rgba(255,255,255,0.1), transparent);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .login-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(28, 16, 8, 0.2);
        color: #ffffff;
    }
    .login-btn:hover::before {
        opacity: 1;
    }
    .login-btn:active {
        transform: translateY(1px);
        box-shadow: 0 2px 10px rgba(28, 16, 8, 0.2);
    }
</style>

<div class="ambient-glow"></div>
<div class="ambient-glow-2"></div>

<div class="container-fluid vh-100 d-flex align-items-center justify-content-center animate-container" style="position: relative; z-index: 1;">
    <div class="row w-100 justify-content-center px-3">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4 px-0">
            <div class="admin-login-card framer-item">
                <div class="card-body p-4 p-sm-5">
                    
                    <div class="text-center mb-5 framer-item framer-delay-1">
                        <!-- Playful luxury logo representation -->
                        <div style="width: 80px; height: 80px; background: #FAF9F7; border: 1.5px solid var(--brand-border); border-radius: 20px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 24px; transform: rotate(-10deg); transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='rotate(0deg) scale(1.05)'" onmouseout="this.style.transform='rotate(-10deg) scale(1)'">
                            <i class="bi bi-gift" style="font-size: 2.2rem; color: var(--brand-accent);"></i>
                        </div>
                        <h2 class="card-title fw-bold m-0" style="font-family: 'Playfair Display', serif; font-size: 32px; color: var(--brand-ink); letter-spacing: -0.5px;">CURATED BY AISSH</h2>
                        <p style="color: #A09A96; font-size: 14px; margin-top: 8px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase;">Admin Portal</p>
                    </div>
                    
                    <% if (typeof flash !== 'undefined' && flash) { %>
                        <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> framer-item framer-delay-1" role="alert" style="border-radius: 12px; font-weight: 500; font-size: 14px; border: none; background-color: <%= flash.type === 'error' ? '#fff5f5' : '#f0fdf4' %>; color: <%= flash.type === 'error' ? '#c53030' : '#15803d' %>;">
                            <i class="bi <%= flash.type === 'error' ? 'bi-exclamation-octagon' : 'bi-check-circle' %> me-2"></i>
                            <%= flash.message %>
                        </div>
                    <% } %>
                    
                    <form action="/admin/login" method="POST">
                        <%- include('../partials/csrf-token') %>
                        
                        <div class="custom-input-group framer-item framer-delay-2">
                            <label for="email" class="form-label" style="font-size: 13px; font-weight: 600; color: var(--brand-ink); margin-bottom: 8px; display: block;">Email Address</label>
                            <div style="position: relative;">
                                <input type="email" class="custom-input" id="email" name="email" placeholder="admin@shubhamcollection.com" required>
                                <i class="bi bi-envelope input-icon"></i>
                            </div>
                        </div>
                        
                        <div class="custom-input-group framer-item framer-delay-3" style="margin-bottom: 32px;">
                            <label for="password" class="form-label" style="font-size: 13px; font-weight: 600; color: var(--brand-ink); margin-bottom: 8px; display: block;">Password</label>
                            <div style="position: relative;">
                                <input type="password" class="custom-input" id="password" name="password" placeholder="Enter your secret" required style="padding-right: 48px;">
                                <i class="bi bi-lock input-icon"></i>
                                <button type="button" class="password-toggle" id="togglePassword">
                                    <i class="bi bi-eye" id="passwordToggleIcon"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="framer-item framer-delay-4">
                            <button type="submit" class="login-btn">
                                Secure Login <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </form>
                    
                    <div class="text-center mt-4 pt-3 framer-item framer-delay-4">
                        <a href="/" style="color: #A09A96; font-size: 14px; font-weight: 500; text-decoration: none; transition: color 0.2s;">
                            <i class="bi bi-arrow-left me-1"></i> Return to Boutique
                        </a>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Password visibility toggle
    document.addEventListener('DOMContentLoaded', () => {
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('password');
        const passwordToggleIcon = document.getElementById('passwordToggleIcon');
        
        if (togglePassword && passwordInput) {
            togglePassword.addEventListener('click', function(e) {
                e.preventDefault();
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                
                // Toggle icon with animation
                passwordToggleIcon.style.transform = 'scale(0.8)';
                passwordToggleIcon.style.opacity = '0';
                
                setTimeout(() => {
                    if (type === 'password') {
                        passwordToggleIcon.classList.remove('bi-eye-slash');
                        passwordToggleIcon.classList.add('bi-eye');
                    } else {
                        passwordToggleIcon.classList.remove('bi-eye');
                        passwordToggleIcon.classList.add('bi-eye-slash');
                    }
                    passwordToggleIcon.style.transform = 'scale(1)';
                    passwordToggleIcon.style.opacity = '1';
                }, 150);
            });
            
            // Allow transition for the icon
            passwordToggleIcon.style.transition = 'all 0.15s ease';
        }
    });
</script>
</body>
</html>
